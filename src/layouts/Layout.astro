---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ranking Atlas — Citation Equity for B2B SaaS Brands',
  description = 'Editorial PR campaigns that get B2B SaaS brands cited by the publishers AI systems trust. Per-campaign, fixed price, guaranteed minimum placements. A modern digital PR alternative to retainer-based agencies.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com",
      "description": "Editorial PR campaigns that get B2B SaaS brands cited by the publishers AI systems trust. Per-campaign, fixed price, guaranteed minimum placements.",
      "knowsAbout": ["Citation Equity", "Editorial Coverage", "AI Search Visibility", "Editorial PR", "Earned Media", "AI Citations", "Expert Commentary", "Journalist Outreach", "B2B SaaS Marketing"],
      "logo": "https://ranking-atlas.com/Logo.png",
      "founder": {
        "@type": "Person",
        "name": "Daniel Grainger",
        "url": "https://ranking-atlas.com/about",
        "sameAs": [
          "https://www.linkedin.com/in/daniel-grainger/",
          "https://onlinelibrary.wiley.com/doi/abs/10.1111/eth.12280"
        ]
      },
      "sameAs": [
        "https://www.linkedin.com/company/ranking-atlas/"
      ]
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[#F5F4EF] font-sans antialiased min-h-screen">
    <div style="position: fixed; inset: 0; pointer-events: none; z-index: -1; background-image: linear-gradient(rgba(93,79,224,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(93,79,224,0.04) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
