---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'Ranking Atlas — Editorial Coverage for Google & AI Search Visibility',
  description = 'Editorial PR that earns coverage on the publishers AI engines cite and Google trusts. Per-campaign, fixed price, guaranteed minimum placements. A modern digital PR alternative to retainer-based agencies.',
  noindex = false,
} = Astro.props;

// Canonical: site origin + pathname, with any trailing slash stripped from
// non-root paths and any query string discarded. Page-level overrides are
// possible via the head slot.
const rawPath = Astro.url.pathname;
const canonicalPath = rawPath === '/' ? '/' : rawPath.replace(/\/+$/, '');
const canonicalHref = `https://ranking-atlas.com${canonicalPath}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalHref} />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com",
      "description": "Editorial PR that earns coverage on the publishers AI engines cite and Google trusts. Per-campaign, fixed price, guaranteed minimum placements.",
      "knowsAbout": ["Citation Equity", "Editorial Coverage", "AI Search Visibility", "Generative Engine Optimisation", "Answer Engine Optimisation", "Editorial PR", "Earned Media", "AI Citations", "Expert Commentary", "Journalist Outreach", "B2B SaaS Marketing"],
      "logo": "https://ranking-atlas.com/Logo.png",
      "founder": {
        "@type": "Person",
        "name": "Daniel Grainger",
        "url": "https://ranking-atlas.com/about",
        "sameAs": [
          "https://www.linkedin.com/in/daniel-grainger/",
          "https://onlinelibrary.wiley.com/doi/abs/10.1111/eth.12280"
        ]
      },
      "sameAs": [
        "https://www.linkedin.com/company/ranking-atlas/"
      ]
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Source+Serif+4:wght@500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-[#FBFAF7] font-sans antialiased min-h-screen">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
