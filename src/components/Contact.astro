---
---

<section id="contact" class="pb-20 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">

      <form id="contact-form" class="bg-white rounded-3xl border border-[#0A0F1E]/8 shadow-md p-8 lg:p-10 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-semibold mb-1.5 text-[#0A0F1E]">
              Name <span class="text-[#1E3A8A]">*</span>
            </label>
            <input id="name" name="name" type="text" required placeholder="Jane Smith"
              class="contact-input w-full border rounded-lg px-4 py-3 text-sm focus:outline-none transition-colors text-[#0A0F1E]"
              style="border-color: rgba(10,15,30,0.13);" />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold mb-1.5 text-[#0A0F1E]">
              Email <span class="text-[#1E3A8A]">*</span>
            </label>
            <input id="email" name="email" type="text" required placeholder="you@example.com"
              class="contact-input w-full border rounded-lg px-4 py-3 text-sm focus:outline-none transition-colors text-[#0A0F1E]"
              style="border-color: rgba(10,15,30,0.13);" />
          </div>
        </div>

        <div>
          <label for="website" class="block text-sm font-semibold mb-1.5 text-[#0A0F1E]">
            Website <span class="text-[#1E3A8A]">*</span>
          </label>
          <input id="website" name="website" type="text" required placeholder="https://yourwebsite.com"
            class="contact-input w-full border rounded-lg px-4 py-3 text-sm focus:outline-none transition-colors text-[#0A0F1E]"
            style="border-color: rgba(10,15,30,0.13);" />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold mb-1.5 text-[#0A0F1E]">
            Message <span class="text-[#1E3A8A]">*</span>
          </label>
          <textarea id="message" name="message" required rows="6"
            placeholder="Tell us about your business, your current editorial coverage, and what you're trying to achieve. The more context you share, the sharper the proposal."
            class="contact-input w-full border rounded-lg px-4 py-3 text-sm focus:outline-none transition-colors text-[#0A0F1E] resize-none"
            style="border-color: rgba(10,15,30,0.13);"></textarea>
        </div>

        <!-- Status messages -->
        <div id="form-success" class="hidden items-center gap-2 bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Message sent! We'll be in touch within one working day.
        </div>
        <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3">
          Something went wrong. Please email <a href="mailto:contact@ranking-atlas.com" class="underline font-medium">contact@ranking-atlas.com</a>
        </div>

        <!-- Submit button -->
        <div class="flex justify-center">
          <button id="form-submit" type="submit"
            class="bg-[#1E3A8A] hover:bg-[#1E40AF] text-white font-semibold py-3 px-8 rounded-md text-sm transition-colors duration-200 flex items-center justify-center gap-2">
            <svg id="submit-mail-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span id="submit-text">Send Message</span>
            <div id="submit-spinner" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
          </button>
        </div>

        <!-- Direct email — inside card -->
        <p class="text-center text-sm text-[#64748B] mt-4">
          Prefer to reach out directly?
          <a href="mailto:contact@ranking-atlas.com"
            class="font-medium text-[#1E3A8A] hover:text-[#1E40AF] transition-colors">
            contact@ranking-atlas.com
          </a>
        </p>
      </form>

      <!-- What happens next -->
      <div class="mt-12 mb-8">
        <p class="text-2xl font-bold tracking-tight text-ink mb-8">What happens next</p>
        <div class="flex flex-col sm:flex-row sm:items-start gap-6 sm:gap-0" id="steps-timeline">

          <!-- Step 1 -->
          <div class="flex flex-col gap-2 flex-1 step-item step-item-1">
            <div class="step-circle step-circle-1 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0">1</div>
            <p class="text-sm font-semibold text-[#0A0F1E]">You Reach Out</p>
            <p class="text-xs leading-relaxed text-[#64748B]">Send the form with your brand details and business context.</p>
          </div>

          <!-- Connector 1 → 2 -->
          <div class="hidden sm:flex items-center shrink-0" style="padding-top: 14px; width: 48px;">
            <div class="w-full h-px overflow-hidden" style="background-color: #E2E8F0;">
              <div class="connector connector-1 h-full" style="background-color: #1E3A8A;"></div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col gap-2 flex-1 step-item step-item-2">
            <div class="step-circle step-circle-2 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0">2</div>
            <p class="text-sm font-semibold text-[#0A0F1E]">We Review</p>
            <p class="text-xs leading-relaxed text-[#64748B]">We baseline your brand's citation pattern across the authoritative publishers AI systems already cite in your vertical.</p>
          </div>

          <!-- Connector 2 → 3 -->
          <div class="hidden sm:flex items-center shrink-0" style="padding-top: 14px; width: 48px;">
            <div class="w-full h-px overflow-hidden" style="background-color: #E2E8F0;">
              <div class="connector connector-2 h-full" style="background-color: #1E3A8A;"></div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col gap-2 flex-1 step-item step-item-3">
            <div class="step-circle step-circle-3 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0">3</div>
            <p class="text-sm font-semibold text-[#0A0F1E]">You Get a Proposal</p>
            <p class="text-xs leading-relaxed text-[#64748B]">We send a campaign proposal with defined scope and a guaranteed placement count within one working day.</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-input:focus {
    border-color: #1E3A8A !important;
    box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.13);
  }

  /* Step animations */
  @keyframes activateStep {
    from { opacity: 0.3; transform: translateY(5px); }
    to   { opacity: 1;   transform: translateY(0); }
  }
  @keyframes activateCircle {
    0%   { background-color: #CBD5E1; box-shadow: none; transform: scale(1); }
    60%  { transform: scale(1.18); box-shadow: 0 0 0 6px rgba(30,58,138,0.18); }
    100% { background-color: #1E3A8A; box-shadow: 0 0 0 3px rgba(30,58,138,0.12); transform: scale(1); }
  }
  @keyframes drawConnector {
    from { width: 0%; }
    to   { width: 100%; }
  }

  /* Initial states — inline styles on connector/circle divs prevent Tailwind override */
  .step-item   { opacity: 0.3; }
  .step-circle { background-color: #CBD5E1 !important; }
  .connector   { width: 0% !important; }

  /* Triggered by IntersectionObserver adding .is-active to #steps-timeline */
  #steps-timeline.is-active .step-item-1   { animation: activateStep   0.5s ease-out 0.1s both; }
  #steps-timeline.is-active .step-circle-1 { animation: activateCircle 0.5s ease-out 0.1s both; }
  #steps-timeline.is-active .connector-1   { animation: drawConnector  0.6s ease-in-out 0.6s both; }
  #steps-timeline.is-active .step-item-2   { animation: activateStep   0.5s ease-out 1.2s both; }
  #steps-timeline.is-active .step-circle-2 { animation: activateCircle 0.5s ease-out 1.2s both; }
  #steps-timeline.is-active .connector-2   { animation: drawConnector  0.6s ease-in-out 1.7s both; }
  #steps-timeline.is-active .step-item-3   { animation: activateStep   0.5s ease-out 2.3s both; }
  #steps-timeline.is-active .step-circle-3 { animation: activateCircle 0.5s ease-out 2.3s both; }
</style>

<script>
  // Trigger step animation when scrolled into view
  var timeline = document.getElementById('steps-timeline');
  if (timeline) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          timeline.classList.add('is-active');
          observer.disconnect();
        }
      });
    }, { threshold: 0.25 });
    observer.observe(timeline);
  }

  document.querySelectorAll('#contact-form').forEach(function(form) {
    var submitBtn = form.querySelector('#form-submit');
    var submitText = form.querySelector('#submit-text');
    var submitSpinner = form.querySelector('#submit-spinner');
    var submitMailIcon = form.querySelector('#submit-mail-icon');
    var successMsg = form.querySelector('#form-success');
    var errorMsg = form.querySelector('#form-error');

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.textContent = 'Sending...';
      if (submitMailIcon) submitMailIcon.classList.add('hidden');
      if (submitSpinner) submitSpinner.classList.remove('hidden');
      if (successMsg) successMsg.classList.add('hidden');
      if (errorMsg) errorMsg.classList.add('hidden');

      var data = {
        name: form.querySelector('#name').value,
        email: form.querySelector('#email').value,
        website: form.querySelector('#website').value,
        message: form.querySelector('#message').value,
        _replyto: 'contact@ranking-atlas.com',
      };

      fetch('https://formspree.io/f/xojkolng', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      })
        .then(function(res) {
          if (res.ok) {
            if (successMsg) {
              successMsg.classList.remove('hidden');
              successMsg.style.display = 'flex';
            }
            form.reset();
          } else {
            if (errorMsg) errorMsg.classList.remove('hidden');
          }
        })
        .catch(function() {
          if (errorMsg) errorMsg.classList.remove('hidden');
        })
        .finally(function() {
          if (submitBtn) submitBtn.disabled = false;
          if (submitText) submitText.textContent = 'Send Message';
          if (submitMailIcon) submitMailIcon.classList.remove('hidden');
          if (submitSpinner) submitSpinner.classList.add('hidden');
        });
    });
  });
</script>
