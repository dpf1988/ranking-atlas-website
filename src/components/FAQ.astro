---
const faqs = [
  {
    q: 'What does a Ranking Atlas campaign cost?',
    a: 'Campaigns start at £3,500. Each campaign is quoted as a fixed price based on scope, target publications, and research depth required. There are no retainers and no monthly minimums.',
  },
  {
    q: 'How many placements does a campaign earn?',
    a: 'Each campaign is delivered with a guaranteed minimum number of placements on agreed publications. The exact number is defined in advance based on scope and target outlets. Most campaigns earn additional placements beyond the guaranteed minimum.',
  },
  {
    q: 'How long does a campaign take?',
    a: 'Campaigns typically run for two to three weeks from launch to delivery. Research and study preparation precedes this; the active outreach window is short and focused.',
  },
  {
    q: 'How are campaigns sourced?',
    a: 'Every campaign is built around primary-source data: client-owned datasets, commissioned surveys, freedom-of-information requests, or publicly available primary records. No campaign relies on press-release rehashes or third-party data summaries.',
  },
  {
    q: 'What standards do you use for research?',
    a: 'Methodology is documented in full and published alongside every study. Sources are named and verifiable. Author attribution is direct. Contact details are provided for editorial follow-up. The standard is what a serious newsroom would accept.',
  },
  {
    q: 'How is coverage measured?',
    a: 'Each campaign closes with a documented list of placements, citation tracking across publications that subsequently reference the work, and visibility measurement across the search environments where the study appears.',
  },
  {
    q: 'Do journalists have access to methodology and data?',
    a: 'Yes. Every published study includes downloadable data, full methodology, and a verified contact for follow-up questions, regional cuts, or additional analysis.',
  },
  {
    q: 'Which publications does Ranking Atlas target?',
    a: "Outreach targets are defined per campaign, focused on the publications and reporters most relevant to the client's industry. Past placements span national and trade outlets across the United States and United Kingdom.",
  },
];
---

<section id="faq" class="bg-[#1A2138] py-16 lg:py-20">

  <div class="max-w-[720px] mx-auto px-6">
    <div class="mb-10">
      <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-white mb-3">
        Frequently Asked Questions
      </h2>
      <p class="text-base text-[#94A3B8] leading-relaxed">
        Everything you need to know before starting a campaign.
      </p>
    </div>

    <div class="divide-y divide-white/10" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item">
          <button
            class="faq-btn w-full flex items-center justify-between gap-4 py-6 text-left group"
            data-index={String(i)}
            type="button"
          >
            <span class="faq-question text-base sm:text-lg font-semibold text-white transition-colors duration-200">
              {faq.q}
            </span>
            <svg class="faq-chevron shrink-0 transition-transform duration-300 text-[#64748B]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-answer hidden pb-6">
            <p class="text-base leading-relaxed text-[#64748B]">
              {faq.a}
            </p>
            {faq.sources && (
              <div class="flex flex-wrap gap-4 mt-3">
                {faq.sources.map((s: { url: string; label: string }) => (
                  <a href={s.url} target="_blank" rel="noopener noreferrer"
                    class="text-xs text-[#8FA4D9]/70 hover:text-[#8FA4D9] transition-colors underline underline-offset-2">
                    {s.label} ↗
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  var openIndex = null;

  document.querySelectorAll('.faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var i = parseInt(btn.getAttribute('data-index') || '0');
      var item = btn.closest('.faq-item');
      var answer = item ? item.querySelector('.faq-answer') : null;
      var chevron = item ? item.querySelector('.faq-chevron') : null;
      var question = item ? item.querySelector('.faq-question') : null;

      if (openIndex === i) {
        // Close
        if (answer) answer.classList.add('hidden');
        if (chevron) chevron.setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
        if (question) question.setAttribute('style', 'color: white');
        openIndex = null;
      } else {
        // Close previously open
        if (openIndex !== null) {
          var prevBtn = document.querySelector('[data-index="' + openIndex + '"]');
          var prevItem = prevBtn ? prevBtn.closest('.faq-item') : null;
          if (prevItem) {
            var pa = prevItem.querySelector('.faq-answer');
            var pc = prevItem.querySelector('.faq-chevron');
            var pq = prevItem.querySelector('.faq-question');
            if (pa) pa.classList.add('hidden');
            if (pc) pc.setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
            if (pq) pq.setAttribute('style', 'color: white');
          }
        }
        // Open current
        if (answer) answer.classList.remove('hidden');
        if (chevron) chevron.setAttribute('style', 'color: #8FA4D9; transform: rotate(180deg)');
        if (question) question.setAttribute('style', 'color: #8FA4D9');
        openIndex = i;
      }
    });
  });
</script>
