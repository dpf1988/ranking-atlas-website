---
interface Props {
  label: string;
  variant?: 'light' | 'dark';
}
const { label, variant = 'light' } = Astro.props;
---
{variant === 'dark' ? (
  <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 mb-6">
    <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
    <span class="text-[11px] font-semibold tracking-[0.14em] uppercase text-white">{label}</span>
  </div>
) : (
  <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#A06CF5]/15 border border-[#A06CF5]/30 mb-6">
    <span class="w-1.5 h-1.5 rounded-full bg-[#1E3A8A]"></span>
    <span class="text-[11px] font-semibold tracking-[0.14em] uppercase text-ink">{label}</span>
  </div>
)}
