---
interface Props {
  href: string;
  label?: string;
}
const { href, label = 'Start a Campaign — £3.5K →' } = Astro.props;
---
<a href={href}
  class="inline-flex items-center justify-center gap-2 bg-[#1E3A8A] hover:bg-[#1E40AF] text-white font-semibold px-6 py-3 rounded-md text-sm transition-colors duration-200">
  {label}
</a>
