---
interface Props {
  href: string;
  label?: string;
}
const { href, label = 'Start a Campaign — £3.5K →' } = Astro.props;
---
<a href={href}
  class="inline-flex items-center justify-center gap-2 bg-[#1E3A8A] hover:bg-[#1E40AF] text-white font-semibold px-6 py-3 rounded text-sm shadow-[0_3px_8px_-2px_rgba(15,27,61,0.22),0_1px_2px_rgba(15,27,61,0.10)] hover:shadow-[0_6px_14px_-4px_rgba(15,27,61,0.28),0_2px_4px_-1px_rgba(15,27,61,0.12)] hover:-translate-y-px transition-all duration-200">
  {label}
</a>
