---
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
---
<a href={href}
  class="inline-flex items-center justify-center gap-2 font-semibold px-6 py-3 border border-[#1E3A8A] text-[#1E3A8A] rounded text-sm transition-colors duration-200 hover:bg-[#1E3A8A]/5">
  {label}
</a>
