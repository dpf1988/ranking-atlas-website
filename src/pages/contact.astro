---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import Eyebrow from '../components/Eyebrow.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Ranking Atlas",
  "url": "https://ranking-atlas.com/contact",
  "description": "Start a fixed-price editorial PR campaign with Ranking Atlas. Guaranteed placements on authoritative publishers. No retainers.",
  "mainEntity": {
    "@type": "Organization",
    "name": "Ranking Atlas",
    "url": "https://ranking-atlas.com",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "contact@ranking-atlas.com",
      "contactType": "sales",
      "availableLanguage": "English"
    }
  }
};
---

<Layout
  title="Contact — Ranking Atlas"
  description="Start a fixed-price editorial PR campaign with Ranking Atlas. Guaranteed placements on authoritative publishers. No retainers. One working day turnaround on proposals."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="pt-20 pb-12 md:pt-28 md:pb-16">
    <div class="max-w-3xl mx-auto px-6">
      <Eyebrow label="Start a Campaign" />
      <h1 class="font-serif font-medium text-[2.25rem] md:text-[3rem] lg:text-[3.5rem] tracking-tight text-ink leading-[1.05] mb-5">
        Start Getting Seen in AI Search
      </h1>
      <p class="text-lg md:text-xl text-body leading-relaxed">
        Tell us about your business and we'll come back with a campaign proposal within one working day.
      </p>
    </div>
  </section>

  <Contact />
</Layout>
