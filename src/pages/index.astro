---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const featuredResearch = [
  {
    href: "/resources/generational-fraud",
    eyebrow: "Data Report",
    title: "Who Actually Gets Scammed in America?",
    description: "Federal fraud and survey data show sharp divides in who gets scammed, how often, and how much they lose.",
  },
  {
    href: "/resources/ai-names-ict-experts",
    eyebrow: "Data Report",
    title: "One Woman for Every Ten: How AI Names the Experts in Tech",
    description: "2,286 individuals extracted from 2,520 AI responses across ChatGPT, Claude, Gemini, and Perplexity. Women made up 20.5% of named ICT experts against a 28% workforce baseline.",
  },
  {
    href: "/resources/saas-pricing-inflation",
    eyebrow: "Data Report",
    title: "Welcome to the SaaSpocalypse",
    description: "Software that can be vibe-coded by a small team has lost all pricing power, while AI-resistant SaaS categories raised entry-tier prices up to three times faster than inflation.",
  },
];

// Editorial eyebrow — pill with navy dot.
const eyebrow = "inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#0A0F1E]/12 mb-5";
const eyebrowDot = "h-1.5 w-1.5 rounded-full bg-[#1E3A8A]";
const eyebrowText = "text-[11px] uppercase tracking-[0.14em] font-semibold text-ink";

// Restrained CTAs — administrative, not conversion-aggressive.
const primaryCta = "inline-flex items-center justify-center bg-[#1E3A8A] hover:bg-[#1E40AF] text-white font-semibold px-5 py-2.5 rounded-md text-sm transition-colors duration-200";
const secondaryCta = "inline-flex items-center justify-center font-semibold px-5 py-2.5 border border-[#1E3A8A] text-[#1E3A8A] rounded-md text-sm transition-colors duration-200 hover:bg-[#1E3A8A]/5";
---

<Layout
  title="Ranking Atlas — Editorial campaigns built on original research and data"
  description="Ranking Atlas produces commissioned studies, proprietary data analysis, and editorial campaigns used by publishers, journalists, and brands seeking broader visibility online."
>

  <!-- ── 1. HERO ── editorial pill + asymmetric layout with right-side study card -->
  <section id="home" class="pt-28 md:pt-32 lg:pt-36 pb-16 md:pb-20 relative" style="background-image: linear-gradient(to right, rgba(15,27,61,0.04) 1px, transparent 1px), linear-gradient(to bottom, rgba(15,27,61,0.04) 1px, transparent 1px); background-size: 48px 48px;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#0A0F1E]/12 mb-7">
            <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-[#1E3A8A]"></span>
            <span class="text-[11px] uppercase tracking-[0.14em] font-semibold text-ink">Digital PR Agency</span>
          </div>
          <h1 class="font-serif font-medium text-[2rem] sm:text-[2.5rem] lg:text-[3.25rem] tracking-tight text-ink leading-[1.05] mb-6">
            <span class="brush-highlight">Research-Led</span><br /> Editorial Campaigns
          </h1>
          <p class="text-lg text-body leading-relaxed mb-7 max-w-[580px]">
            We help brands become <span class="font-semibold text-[#1E3A8A]">cited sources across trusted publications</span>, strengthening both search visibility and AI discoverability.
          </p>
          <div class="flex flex-wrap items-center gap-3">
            <a href="/contact" class={primaryCta}>Start a Campaign</a>
            <a href="/resources" class={secondaryCta}>See our research</a>
          </div>
        </div>

        <!-- Right-side (mobile: stacks below CTAs): screenshot of landed editorial coverage -->
        <div class="lg:col-span-6 lg:-mt-8 lg:-mr-6 xl:-mr-12 relative">
          <img
            src="/images/formidable-ai-ict-experts.png"
            alt="Ranking Atlas research featured in Formidable: analysis of 2,500 AI queries finding women accounted for just 16.1% of expert mentions across ChatGPT, Claude, Gemini and Perplexity"
            class="w-full h-auto rounded-lg shadow-[0_30px_60px_-15px_rgba(15,27,61,0.25),0_10px_25px_-10px_rgba(15,27,61,0.15)]"
          />
          <!-- Discreet external link overlay: opens the actual Formidable article in a new tab -->
          <a
            href="https://beformidable.com/p/the-backlash-to-reese-witherspoon-reveals-a-more-nuanced-ai-problem"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Read the article on Formidable"
            title="Read on Formidable"
            class="absolute bottom-3 right-3 inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/95 backdrop-blur-sm border border-[#0A0F1E]/10 shadow-md text-[#1E3A8A] hover:bg-white hover:border-[#0A0F1E]/25 hover:text-[#1E40AF] transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7"/><polyline points="7 7 17 7 17 17"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile-only section divider: short hairline + navy dot, echoing the eyebrow visual language -->
  <div class="lg:hidden flex items-center justify-center gap-3 py-2">
    <span aria-hidden="true" class="h-px w-10 bg-[#0A0F1E]/15"></span>
    <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-[#1E3A8A]/60"></span>
    <span aria-hidden="true" class="h-px w-10 bg-[#0A0F1E]/15"></span>
  </div>

  <!-- ── 3. WHAT WE DO ── three elegant cards with restrained iconography + check details -->
  <section class="bg-[#F4F0E9] py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[720px] mx-auto mb-10">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>What we do</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-5"><span class="brush-underline">Research, Editorial Production, Placement</span></h2>
        <p class="text-lg text-body leading-relaxed">
          Every campaign begins with <span class="font-semibold text-[#1E3A8A]">original research and primary-source data</span>, then moves through full editorial production and targeted outreach.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <!-- Magnifying glass examining a small bar chart -->
              <circle cx="10" cy="10" r="7"/>
              <line x1="15.5" y1="15.5" x2="21" y2="21"/>
              <line x1="7" y1="13" x2="7" y2="10"/>
              <line x1="10" y1="13" x2="10" y2="7"/>
              <line x1="13" y1="13" x2="13" y2="11"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Original Research</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Studies built from primary-source data, then analysed to surface the trends and editorial angles a newsroom can use.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Proprietary datasets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Commissioned surveys</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Statistical analysis</li>
          </ul>
        </div>

        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <!-- Folded newspaper: two pages each with a headline and body lines -->
              <rect x="3" y="4" width="18" height="16" rx="1"/>
              <line x1="12" y1="4" x2="12" y2="20"/>
              <line x1="5" y1="8" x2="10" y2="8"/>
              <line x1="5" y1="12" x2="9" y2="12"/>
              <line x1="5" y1="15" x2="9" y2="15"/>
              <line x1="14" y1="8" x2="19" y2="8"/>
              <line x1="14" y1="12" x2="18" y2="12"/>
              <line x1="14" y1="15" x2="18" y2="15"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Editorial Production</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Research structured for editorial use, including documented methodology, downloadable data, and verified contact attribution.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Documented methodology</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Downloadable datasets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Named author attribution</li>
          </ul>
        </div>

        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <!-- Publication page with verified badge in the upper-right corner -->
              <rect x="3" y="6" width="14" height="15" rx="1"/>
              <line x1="6" y1="11" x2="14" y2="11"/>
              <line x1="6" y1="14" x2="14" y2="14"/>
              <line x1="6" y1="17" x2="11" y2="17"/>
              <circle cx="19" cy="6" r="3.5" fill="#1E3A8A" stroke="none"/>
              <polyline points="17.5 6 18.5 7 20.5 5" stroke="white" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Targeted Placement</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Outreach focused on the publications, reporters, and subject areas most relevant to the client's industry.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Industry-relevant outlets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Named reporter targeting</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Guaranteed minimums</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3b. WHY EDITORIAL COVERAGE MATTERS ── split-layout intro + stat callouts + pullquote -->
  <section class="py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[760px] mx-auto mb-10">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>Context</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-6">
          <span class="brush-underline">Why Editorial Coverage Matters In Search</span>
        </h2>
        <p class="text-lg text-body leading-relaxed">
          Google and AI search engines <span class="font-semibold text-[#1E3A8A]">increasingly rely on publisher references</span> when determining which brands surface in results and generated answers. The mechanism is the same across both: <span class="font-semibold text-[#1E3A8A]">brands cited by trusted publications appear more often</span>, in more places, to more buyers.
        </p>
      </div>

      <!-- Stat callouts: three numeric pillars, staggered vertical rhythm -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">61</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-4">Organic Results Are Shrinking</h3>

          <!-- Before/after bar pair: left = CTR before AI Overview (full), right = CTR after AI Overview (39%, faint ghost shows lost portion) -->
          <div class="flex justify-center mb-4">
            <svg viewBox="0 0 110 110" class="w-[110px] h-[110px]" role="img" aria-label="Two bars side by side: left bar at full height represents click-through before AI Overviews, right bar at thirty-nine percent height represents click-through after AI Overviews">
              <!-- Left bar: full CTR (before) -->
              <rect x="22" y="15" width="28" height="85" fill="#1E3A8A"/>
              <!-- Right bar: ghost of lost portion (the 61% drop) -->
              <rect x="60" y="15" width="28" height="85" fill="rgba(15, 27, 61, 0.10)"/>
              <!-- Right bar: remaining CTR (39%) -->
              <rect x="60" y="67" width="28" height="33" fill="#1E3A8A"/>
              <!-- Baseline -->
              <line x1="15" y1="100" x2="95" y2="100" stroke="rgba(15, 27, 61, 0.15)" stroke-width="1"/>
            </svg>
          </div>

          <p class="text-sm text-body leading-relaxed">
            AI Overviews compress click-through to ranked pages. The traditional path of ranking and earning the click is narrowing.
          </p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 md:mt-8 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">10–14</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-4">AI Engines Move Buyer Research</h3>

          <!-- Trajectory: line rises from near-zero on the left to a navy dot on the right; faint area fill underneath -->
          <div class="flex justify-center mb-4">
            <svg viewBox="0 0 110 110" class="w-[110px] h-[110px]" role="img" aria-label="Line trajectory rising from near zero on the left to a high point on the right, representing AI engine referral traffic growing from negligible to ten to fourteen percent over eighteen months">
              <!-- Area fill under the curve -->
              <path d="M 10 95 C 40 92 65 70 100 25 L 100 100 L 10 100 Z" fill="#1E3A8A" fill-opacity="0.08"/>
              <!-- Line -->
              <path d="M 10 95 C 40 92 65 70 100 25" fill="none" stroke="#1E3A8A" stroke-width="2" stroke-linecap="round"/>
              <!-- End dot -->
              <circle cx="100" cy="25" r="3" fill="#1E3A8A"/>
              <!-- Baseline -->
              <line x1="10" y1="100" x2="100" y2="100" stroke="rgba(15, 27, 61, 0.15)" stroke-width="1"/>
            </svg>
          </div>

          <p class="text-sm text-body leading-relaxed">
            AI engines now drive a meaningful share of buyer research traffic. Where audiences look up answers is shifting quickly.
          </p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">96.55</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-4">Pages That Earn Zero Traffic</h3>

          <!-- 10x10 dot grid: 96 navy dots = pages with zero traffic; 4 faint = the small share that earn meaningful traffic -->
          <div class="flex justify-center mb-4">
            <svg viewBox="0 0 110 110" class="w-[110px] h-[110px]" role="img" aria-label="Grid of one hundred dots representing all pages on the web; ninety-six are solid navy to represent pages with zero search traffic, four are faint to represent the small share that earn meaningful traffic">
              {Array.from({ length: 100 }, (_, i) => {
                const col = i % 10;
                const row = Math.floor(i / 10);
                const cx = 5.5 + col * 11;
                const cy = 5.5 + row * 11;
                const isExceptional = [0, 1, 10, 11].includes(i);
                return (
                  <circle
                    cx={cx}
                    cy={cy}
                    r={isExceptional ? 2.5 : 3}
                    fill={isExceptional ? "rgba(15, 27, 61, 0.15)" : "#1E3A8A"}
                  />
                );
              })}
            </svg>
          </div>

          <p class="text-sm text-body leading-relaxed">
            Most pages on the web receive no search traffic at all. The handful that do are disproportionately cited by trusted publishers.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ── 4. FEATURED RESEARCH ── flagship + 2 secondary, study metadata pills -->
  <section class="bg-[#F4F0E9] py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[640px] mx-auto mb-10">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>Research</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-5"><span class="brush-underline">Featured Research</span></h2>
        <p class="text-lg text-body leading-relaxed mb-5">
          Original studies built around primary-source data, published with full methodology.
        </p>
        <a href="/resources" class="text-sm text-[#1E3A8A] hover:text-[#1E40AF] font-semibold">
          View all research →
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">
        <!-- Flagship -->
        <a href={featuredResearch[0].href} class="group lg:col-span-7 bg-white border border-[#0A0F1E]/12 rounded-md p-10 md:p-12 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[10px] uppercase tracking-[0.16em] text-[#1E3A8A] font-semibold">Featured Study</span>
            <span aria-hidden="true" class="h-px w-8 bg-[#1E3A8A]/40"></span>
            <span class="text-[10px] uppercase tracking-[0.14em] text-muted font-medium">{featuredResearch[0].eyebrow}</span>
          </div>
          <h3 class="font-serif font-semibold text-2xl md:text-[2rem] tracking-tight text-ink mb-5 leading-[1.2] group-hover:text-brand-navy transition-colors max-w-[560px]">
            {featuredResearch[0].title}
          </h3>
          <p class="text-base md:text-lg text-body leading-relaxed mb-6 max-w-[540px]">
            {featuredResearch[0].description}
          </p>

          <!-- Subtle table preview from the study -->
          <figure class="mb-7 max-w-[560px]">
            <figcaption class="flex items-center gap-2 mb-2.5">
              <span class="text-[10px] uppercase tracking-[0.14em] text-muted font-semibold">Index preview</span>
              <span aria-hidden="true" class="h-px flex-1 bg-[#0A0F1E]/10"></span>
              <span class="text-[10px] uppercase tracking-[0.14em] text-muted font-medium">Composite score</span>
            </figcaption>
            <div class="rounded-sm border border-[#0A0F1E]/10 bg-white p-5 space-y-3" role="figure" aria-label="Index preview: composite scores by age cohort">
              <div class="flex items-center gap-3">
                <span class="w-4 text-[11px] font-semibold text-ink text-right">1</span>
                <span class="w-24 shrink-0 text-[12.5px] font-semibold text-ink">Ages 50–64</span>
                <div class="flex-1 h-2 rounded-full bg-[#0A0F1E]/[0.06] overflow-hidden">
                  <div class="h-full w-[84.6%] bg-[#1E3A8A] rounded-full"></div>
                </div>
                <span class="w-10 text-right text-[13px] font-bold text-[#1E3A8A]">84.6</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="w-4 text-[11px] font-medium text-body text-right">2</span>
                <span class="w-24 shrink-0 text-[12.5px] font-medium text-body">Ages 25–34</span>
                <div class="flex-1 h-2 rounded-full bg-[#0A0F1E]/[0.06] overflow-hidden">
                  <div class="h-full w-[60.4%] bg-[#1E3A8A]/55 rounded-full"></div>
                </div>
                <span class="w-10 text-right text-[13px] font-medium text-body">60.4</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="w-4 text-[11px] font-medium text-body text-right">3</span>
                <span class="w-24 shrink-0 text-[12.5px] font-medium text-body">Ages 35–49</span>
                <div class="flex-1 h-2 rounded-full bg-[#0A0F1E]/[0.06] overflow-hidden">
                  <div class="h-full w-[52.4%] bg-[#1E3A8A]/50 rounded-full"></div>
                </div>
                <span class="w-10 text-right text-[13px] font-medium text-body">52.4</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="w-4 text-[11px] font-medium text-muted text-right">4</span>
                <span class="w-24 shrink-0 text-[12.5px] font-medium text-muted">Ages 65+</span>
                <div class="flex-1 h-2 rounded-full bg-[#0A0F1E]/[0.06] overflow-hidden">
