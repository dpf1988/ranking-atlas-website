---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const featuredResearch = [
  {
    href: "/resources/generational-fraud",
    eyebrow: "Data Report",
    title: "The 2026 Generational Fraud Index",
    description: "A composite index ranking generational fraud risk across the United States, built from six federal and survey sources.",
  },
  {
    href: "/resources/ai-names-ict-experts",
    eyebrow: "Data Report",
    title: "Who AI Names When You Ask for ICT Experts",
    description: "2,286 individuals extracted from 2,520 AI responses across ChatGPT, Claude, Gemini, and Perplexity. Gender, role, and consensus data for every person cited.",
  },
  {
    href: "/resources/saas-pricing-inflation",
    eyebrow: "Data Report",
    title: "SaaS Price Comparison 2020–2026",
    description: "Entry-tier pricing for 65 SaaS tools tracked over six years across 12 categories, with Wayback Machine verification on every data point.",
  },
];

// Editorial eyebrow — pill with navy dot.
const eyebrow = "inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#0A0F1E]/12 mb-5";
const eyebrowDot = "h-1.5 w-1.5 rounded-full bg-[#1E3A8A]";
const eyebrowText = "text-[11px] uppercase tracking-[0.14em] font-semibold text-ink";

// Restrained CTAs — administrative, not conversion-aggressive.
const primaryCta = "inline-flex items-center justify-center bg-[#1E3A8A] hover:bg-[#1E40AF] text-white font-semibold px-5 py-2.5 rounded-md text-sm transition-colors duration-200";
const secondaryCta = "inline-flex items-center justify-center font-semibold px-5 py-2.5 border border-[#1E3A8A] text-[#1E3A8A] rounded-md text-sm transition-colors duration-200 hover:bg-[#1E3A8A]/5";
---

<Layout
  title="Ranking Atlas — Editorial campaigns built on original research and data"
  description="Ranking Atlas produces commissioned studies, proprietary data analysis, and editorial campaigns used by publishers, journalists, and brands seeking broader visibility online."
>

  <!-- ── 1. HERO ── editorial pill + asymmetric layout with right-side study card -->
  <section id="home" class="pt-28 md:pt-32 lg:pt-36 pb-16 md:pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#0A0F1E]/12 mb-7">
            <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-[#1E3A8A]"></span>
            <span class="text-[11px] uppercase tracking-[0.14em] font-semibold text-ink">Digital PR Agency</span>
          </div>
          <h1 class="font-serif font-medium text-[2rem] sm:text-[2.5rem] lg:text-[3.25rem] tracking-tight text-ink leading-[1.05] mb-6">
            <span class="brush-highlight">Research-Led</span><br /> Editorial Campaigns
          </h1>
          <p class="text-lg text-body leading-relaxed mb-7 max-w-[580px]">
            We help brands become <span class="font-semibold text-[#1E3A8A]">cited sources across trusted publications</span>, strengthening both search visibility and AI discoverability.
          </p>
          <div class="flex flex-wrap items-center gap-3">
            <a href="/contact" class={primaryCta}>Start a Campaign</a>
            <a href="/resources" class={secondaryCta}>See our research</a>
          </div>
        </div>

        <!-- Right-side: screenshot of landed editorial coverage -->
        <div class="lg:col-span-6 hidden lg:block lg:-mt-8 lg:-mr-6 xl:-mr-12">
          <img
            src="/images/formidable-ai-ict-experts.png"
            alt="Ranking Atlas research featured in Formidable: analysis of 2,500 AI queries finding women accounted for just 16.1% of expert mentions across ChatGPT, Claude, Gemini and Perplexity"
            class="w-full h-auto rounded-lg shadow-[0_30px_60px_-15px_rgba(15,27,61,0.25),0_10px_25px_-10px_rgba(15,27,61,0.15)]"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. PUBLISHER MARQUEE ── "Featured In" eyebrow + contained marquee -->
  <div class="bg-white py-10 border-y border-[#0A0F1E]/10">
    <div class="max-w-5xl mx-auto px-6 mb-6">
      <div class="flex items-center justify-center gap-3">
        <span aria-hidden="true" class="h-px w-8 bg-[#0A0F1E]/20"></span>
        <span class="text-[11px] uppercase tracking-[0.16em] font-semibold text-muted">Featured in</span>
        <span aria-hidden="true" class="h-px w-8 bg-[#0A0F1E]/20"></span>
      </div>
    </div>
    <div class="relative overflow-hidden w-full">
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
      <div class="flex gap-3 animate-marquee-slow whitespace-nowrap w-max">
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">TechCrunch</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Wired</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Financial Times</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Ars Technica</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">VentureBeat</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Dark Reading</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">SecurityWeek</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">American Banker</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Fintech Futures</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">TechCrunch</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Wired</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Financial Times</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Ars Technica</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">VentureBeat</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Dark Reading</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">SecurityWeek</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">American Banker</span>
        <span class="px-5 py-2 rounded-full border border-[#0A0F1E]/15 bg-white text-sm font-medium text-[#0A0F1E] whitespace-nowrap shrink-0">Fintech Futures</span>
      </div>
    </div>
  </div>

  <!-- ── 3. WHAT WE DO ── three elegant cards with restrained iconography + check details -->
  <section class="py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[720px] mx-auto mb-10">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>What we do</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-5"><span class="brush-underline">Research, Editorial Production, Placement</span></h2>
        <p class="text-lg text-body leading-relaxed">
          Every campaign begins with <span class="font-semibold text-[#1E3A8A]">original research and primary-source data</span>, then moves through full editorial production and targeted outreach.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v3"/><path d="M3 8h18"/><path d="M7 12h10"/><path d="M7 16h6"/><rect x="3" y="8" width="18" height="13" rx="1"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Original Research</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Studies built from proprietary datasets, commissioned research, and publicly available primary sources.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Proprietary datasets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Commissioned surveys</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Federal records</li>
          </ul>
        </div>

        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Editorial Production</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Research structured for editorial use, including documented methodology, downloadable data, and verified contact attribution.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Documented methodology</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Downloadable datasets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Named author attribution</li>
          </ul>
        </div>

        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="1.5" fill="#1E3A8A"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold tracking-tight text-ink mb-2">Targeted Placement</h3>
          <p class="text-sm text-body leading-relaxed mb-5 flex-1">Outreach focused on the publications, reporters, and subject areas most relevant to the client's industry.</p>
          <ul class="space-y-1.5 text-[12px] text-muted pt-4 border-t border-[#0A0F1E]/08">
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Industry-relevant outlets</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Named reporter targeting</li>
            <li class="flex items-center gap-2"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Guaranteed minimums</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3b. WHY EDITORIAL COVERAGE MATTERS ── split-layout intro + stat callouts + pullquote -->
  <section class="bg-[#F4F0E9] py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[760px] mx-auto mb-14">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>Context</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-6">
          <span class="brush-underline">Why Editorial Coverage Matters In Search</span>
        </h2>
        <p class="text-lg text-body leading-relaxed">
          Google and AI search engines <span class="font-semibold text-[#1E3A8A]">increasingly rely on publisher references</span> when determining which brands surface in results and generated answers. The mechanism is the same across both: <span class="font-semibold text-[#1E3A8A]">brands cited by trusted publications appear more often</span>, in more places, to more buyers.
        </p>
      </div>

      <!-- Stat callouts: three numeric pillars, staggered vertical rhythm -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">61</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Organic Results Are Shrinking</h3>
          <p class="text-sm text-body leading-relaxed">
            When Google shows an AI Overview, click-through to the underlying pages drops by 61% on average <span class="text-muted">(<a href="https://www.dataslayer.ai/blog/google-ai-overviews-the-end-of-traditional-ctr-and-how-to-adapt-in-2025" target="_blank" rel="noopener noreferrer" class="text-brand-navy hover:underline">Seer Interactive, 2024</a>)</span>. The traditional path of ranking a page and earning the click is narrowing.
          </p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 md:mt-8 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">10–14</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">AI Engines Move Buyer Research</h3>
          <p class="text-sm text-body leading-relaxed">
            Referral traffic to publishers from ChatGPT, Perplexity, Claude, and Gemini grew from negligible to 10–14% of total traffic over 18 months <span class="text-muted">(<a href="https://digitalcontentnext.org/blog/2025/05/06/googles-ai-overviews-linked-to-lower-publisher-clicks/" target="_blank" rel="noopener noreferrer" class="text-brand-navy hover:underline">Digital Content Next, 2025</a>)</span>.
          </p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors">
          <div class="flex items-baseline gap-1 mb-3">
            <span class="font-serif font-semibold text-[2.25rem] text-[#1E3A8A] leading-none">96.55</span>
            <span class="font-serif font-semibold text-2xl text-[#1E3A8A] leading-none">%</span>
          </div>
          <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Publisher References Are The Signal</h3>
          <p class="text-sm text-body leading-relaxed">
            96.55% of pages on the web receive no organic search traffic at all <span class="text-muted">(<a href="https://ahrefs.com/blog/search-traffic-study/" target="_blank" rel="noopener noreferrer" class="text-brand-navy hover:underline">Ahrefs, 2024</a>)</span>. Pages that do receive meaningful visibility are disproportionately referenced by established publications and trusted domains.
          </p>
        </div>
      </div>

      <blockquote class="max-w-[760px] mx-auto text-center font-serif text-xl md:text-2xl italic text-ink leading-snug">
        <span aria-hidden="true" class="block mx-auto mb-5 h-px w-12 bg-[#1E3A8A]"></span>
        Search visibility increasingly depends on whether brands are referenced by publishers Google and AI engines already trust.
      </blockquote>
    </div>
  </section>

  <!-- ── 4. RESEARCH PROCESS ── structured horizontal process system with connector line -->
  <section class="py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-[640px] mx-auto mb-12">
        <div class={eyebrow}>
          <span aria-hidden="true" class={eyebrowDot}></span>
          <span class={eyebrowText}>Research process</span>
        </div>
        <h2 class="font-serif font-semibold text-2xl md:text-3xl tracking-tight text-ink leading-tight mb-5"><span class="brush-underline">From Primary Data To Placement</span></h2>
        <p class="text-base text-body leading-relaxed">
          Four stages, run sequentially. Each stage produces an <span class="font-semibold text-[#1E3A8A]">editorial artefact</span> a serious newsroom can use.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5 font-mono text-[11px] font-semibold text-[#1E3A8A] tracking-wider">01</div>
          <h4 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Data Sourcing</h4>
          <p class="text-sm text-body leading-relaxed">Official datasets, commissioned surveys, proprietary client data, and publicly available primary records.</p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5 font-mono text-[11px] font-semibold text-[#1E3A8A] tracking-wider">02</div>
          <h4 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Analysis</h4>
          <p class="text-sm text-body leading-relaxed">Statistical analysis, trend identification, and editorial angle development.</p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5 font-mono text-[11px] font-semibold text-[#1E3A8A] tracking-wider">03</div>
          <h4 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Editorial Production</h4>
          <p class="text-sm text-body leading-relaxed">Methodology, downloadable datasets, source attribution, and publication-ready formatting.</p>
        </div>
        <div class="bg-white border border-[#0A0F1E]/10 rounded-md p-7 hover:border-[#0A0F1E]/25 transition-colors flex flex-col">
          <div class="w-9 h-9 rounded-sm bg-[#F4F0E9] flex items-center justify-center mb-5 font-mono text-[11px] font-semibold text-[#1E3A8A] tracking-wider">04</div>
          <h4 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink mb-2">Outreach</h4>
          <p class="text-sm text-body leading-relaxed">Distribution focused on the publications, reporters, and subject areas most relevant to the campaign.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. FEATURED RESEARCH ── flagship + 2 secondary, study metadata pills -->
