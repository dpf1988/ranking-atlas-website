---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Ranking Atlas — Digital PR Agency">

  <!-- ── HERO ── -->
  <section id="home" class="bg-white min-h-screen flex items-center pt-16 lg:pt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-12 lg:pt-6 lg:pb-16 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left -->
        <div>
          <!-- Category label -->
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-5 text-[#64748B]">
            Digital PR Agency
          </p>

          <!-- Headline -->
          <h1 class="font-black leading-[1.05] tracking-tight mb-2">
            <div class="pb-2 text-[10vw] sm:text-[56px] lg:text-[60px]"
              style="background: linear-gradient(90deg, #0A0F1E 0%, #4F46E5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              Pay Per Campaign.
            </div>
            <div class="relative whitespace-nowrap text-[8.5vw] sm:text-[48px] lg:text-[52px]"
              style="display: inline-block; background: linear-gradient(90deg, #0A0F1E 0%, #4F46E5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              Not Per Month.
              <svg
                viewBox="0 0 340 12"
                class="absolute left-0 w-full"
                style="bottom: -14px; height: 12px;"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M2 8 C30 3, 60 10, 90 6 S150 2, 180 7 S240 11, 270 5 S310 2, 338 7"
                  stroke="#4F46E5"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          </h1>

          <div class="mb-5"></div>

          <!-- Subheadline -->
          <p class="text-lg sm:text-xl leading-relaxed max-w-xl mb-6 text-[#64748B]">
            High-authority backlinks through earned media. Minimum 8 links guaranteed. No retainers, no contracts.
          </p>

          <!-- Stat bar -->
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-8">
            {[
              '8–12 Links Per Campaign (Minimum!)',
              '100% Link Guarantee',
              'No Retainers',
            ].map((stat, i) => (
              <div class="flex items-center gap-1.5 shrink-0">
                {i > 0 && <span class="hidden sm:inline text-[#0A0F1E]/20 mx-1">·</span>}
                <!-- CheckCircle -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-xs font-medium whitespace-nowrap text-[#0A0F1E]">{stat}</span>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contact"
              class="inline-flex items-center justify-center gap-2 bg-[#4F46E5] hover:bg-[#4338CA] text-white font-bold px-8 py-4 rounded-lg text-base transition-all duration-200 hover:shadow-[0_0_20px_4px_rgba(245,197,24,0.35)] hover:-translate-y-0.5">
              Start a Campaign – $3.5K
              <!-- ChevronRight -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
            <a href="#case-study"
              class="inline-flex items-center justify-center gap-2 border-2 border-[#4F46E5]/50 hover:border-[#4F46E5] text-[#4F46E5] font-bold px-8 py-4 rounded-lg text-base transition-all duration-200 hover:shadow-[0_0_16px_2px_rgba(245,197,24,0.25)] hover:-translate-y-0.5">
              See Case Study
            </a>
          </div>
        </div>

        <!-- Right: Hero Illustration -->
        <div class="hidden lg:flex items-center justify-center">
          <svg viewBox="0 0 460 420" fill="none" xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-lg mx-auto" aria-hidden="true">
            <defs>
              <filter id="sh" x="-15%" y="-10%" width="140%" height="150%">
                <feDropShadow dx="0" dy="8" stdDeviation="16" flood-color="#0A0F1E" flood-opacity="0.14" />
              </filter>
              <filter id="sh2" x="-20%" y="-20%" width="150%" height="160%">
                <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#4F46E5" flood-opacity="0.35" />
              </filter>
            </defs>
            <!-- Browser chrome -->
            <rect x="40" y="30" width="380" height="368" rx="14" fill="#FFFFFF" filter="url(#sh)" />
            <rect x="40" y="30" width="380" height="40" rx="14" fill="#F1F5F9" />
            <rect x="40" y="56" width="380" height="14" fill="#F1F5F9" />
            <circle cx="66" cy="50" r="5" fill="#64748B" opacity="0.22" />
            <circle cx="82" cy="50" r="5" fill="#64748B" opacity="0.22" />
            <circle cx="98" cy="50" r="5" fill="#64748B" opacity="0.22" />
            <rect x="116" y="42" width="240" height="16" rx="8" fill="#FFFFFF" />
            <rect x="126" y="47" width="120" height="6" rx="3" fill="#64748B" opacity="0.30" />
            <!-- Masthead -->
            <text x="230" y="108" text-anchor="middle"
              font-family="Georgia, serif" font-size="24" font-weight="700"
              fill="#0A0F1E" letter-spacing="4">The Guardian</text>
            <line x1="60" y1="116" x2="400" y2="116" stroke="#0A0F1E" stroke-width="2" />
            <line x1="60" y1="120" x2="400" y2="120" stroke="#0A0F1E" stroke-width="0.5" />
            <!-- Section tag -->
            <rect x="60" y="130" width="64" height="18" rx="3" fill="#4F46E5" />
            <rect x="67" y="135.5" width="50" height="7" rx="3" fill="#FFFFFF" opacity="0.85" />
            <!-- Headline -->
            <rect x="60" y="158" width="320" height="16" rx="4" fill="#0A0F1E" />
            <rect x="60" y="180" width="280" height="16" rx="4" fill="#0A0F1E" />
            <!-- Author -->
            <circle cx="74" cy="214" r="10" fill="#F1F5F9" stroke="#64748B" stroke-width="0.8" stroke-opacity="0.4" />
            <circle cx="74" cy="211" r="4" fill="#64748B" opacity="0.35" />
            <ellipse cx="74" cy="220" rx="6" ry="4" fill="#64748B" opacity="0.25" />
            <rect x="90" y="208" width="80" height="7" rx="3" fill="#64748B" opacity="0.65" />
            <rect x="90" y="219" width="55" height="6" rx="3" fill="#64748B" opacity="0.35" />
            <line x1="60" y1="232" x2="400" y2="232" stroke="#F1F5F9" stroke-width="1.2" />
            <!-- Body text -->
            <rect x="60" y="242" width="320" height="7" rx="3" fill="#64748B" opacity="0.32" />
            <rect x="60" y="255" width="308" height="7" rx="3" fill="#64748B" opacity="0.32" />
            <rect x="60" y="268" width="315" height="7" rx="3" fill="#64748B" opacity="0.32" />
            <rect x="60" y="281" width="260" height="7" rx="3" fill="#64748B" opacity="0.32" />
            <!-- Pull quote -->
            <rect x="60" y="300" width="4" height="48" rx="2" fill="#4F46E5" />
            <rect x="74" y="306" width="210" height="9" rx="3" fill="#0A0F1E" opacity="0.52" />
            <rect x="74" y="321" width="180" height="9" rx="3" fill="#0A0F1E" opacity="0.52" />
            <rect x="74" y="336" width="130" height="9" rx="3" fill="#0A0F1E" opacity="0.38" />
            <!-- More body -->
            <rect x="60" y="360" width="316" height="7" rx="3" fill="#64748B" opacity="0.25" />
            <rect x="60" y="373" width="270" height="7" rx="3" fill="#64748B" opacity="0.25" />
            <!-- Chain-link badge -->
            <circle cx="390" cy="372" r="24" fill="#4F46E5" filter="url(#sh2)" />
            <g transform="translate(380, 362) scale(0.85)" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </g>
          </svg>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PUBLICATIONS BAR ── -->
  <div class="bg-[#F8FAFC] border-y border-[#0A0F1E]/8 py-8 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-5">
      <p class="text-center text-xs font-semibold tracking-[0.2em] uppercase text-[#64748B]">
        We Target Publications Including
      </p>
    </div>
    <div class="relative overflow-hidden">
      <div class="flex items-center animate-scroll whitespace-nowrap">
        {['The Guardian', 'BBC', 'Forbes', 'Bloomberg', 'The Telegraph', 'Daily Mail', 'The Sun', 'New York Times',
          'The Guardian', 'BBC', 'Forbes', 'Bloomberg', 'The Telegraph', 'Daily Mail', 'The Sun', 'New York Times'].map((pub, i) => (
          <span class="inline-flex items-center shrink-0">
            <span class="font-semibold text-lg hover:text-[#0A0F1E] transition-colors px-10 text-[#0A0F1E]">
              {pub}
            </span>
            <span class="font-light shrink-0" style="color: rgba(79,70,229,0.3);">|</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ── SERVICES ── -->
  <section id="services" class="bg-white pt-12 pb-24 lg:pt-14 lg:pb-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-black mb-4 text-[#0A0F1E]">
          Our Digital PR Services
        </h2>
        <p class="text-xl max-w-2xl mx-auto text-[#64748B]">
          Three ways we get your brand featured in major publications.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Reactive PR -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- TrendingUp -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Reactive PR</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We monitor trending events, Google Trends, and breaking news to secure rapid link acquisition.</p>
          <ul class="space-y-2.5 mb-6">
            {['Google Trends monitoring', 'Breaking news response', 'Rapid link acquisition', 'Real-time pitching'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/reactive-pr.png" alt="Reactive PR example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

        <!-- Expert Commentary -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- MessageSquare -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Expert Commentary</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We position your brand as a thought leader by securing expert tips and insights in top-tier publications.</p>
          <ul class="space-y-2.5 mb-6">
            {['Thought leadership', 'Expert tips & insights', 'High-authority placements', 'Brand authority building'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/expert-pr.png" alt="Expert Commentary example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

        <!-- Data Campaigns -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- BarChart3 -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <path d="M18 20V10"/>
              <path d="M12 20V4"/>
              <path d="M6 20v-6"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Data Campaigns</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We create original research stories using government statistics and proprietary datasets that generate high-authority backlinks at scale.</p>
          <ul class="space-y-2.5 mb-6">
            {['Government statistics', 'Proprietary data analysis', 'Original research stories', 'Scalable campaigns'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/data-campaign.png" alt="Data Campaigns example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

      </div>
    </div>
  </section>

  <!-- ── GUARANTEES ── -->
  <section class="bg-[#0A0F1E] py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-black text-white mb-4">
          Digital PR with link guarantees
        </h2>
        <p class="text-xl max-w-2xl mx-auto text-[#64748B]">
          We run unlimited stories for you until link numbers are achieved.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- 100% Earned Links -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Award -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">100% Earned Links</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">Every link is genuinely earned through editorial placements — no paid inserts, ever.</p>
        </div>

        <!-- 100% Link Guarantee -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Shield -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">100% Link Guarantee</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">We run unlimited stories until your agreed link count is achieved.</p>
        </div>

        <!-- No Long-Term Contracts -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- FileText -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">No Long-Term Contracts</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">Campaign-by-campaign model. Stay because of results, not commitments.</p>
        </div>

        <!-- Highly Scalable -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Zap -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">Highly Scalable</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">From 10 links to 80 — our process scales to match your growth ambitions.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CASE STUDY ── -->
  <section id="case-study" class="bg-[#F8FAFC] py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-black mb-4 text-[#0A0F1E]">Case Study</h2>
        <p class="text-xl text-[#64748B]">Real results from a real client.</p>
      </div>

      <div class="bg-white rounded-3xl border border-[#0A0F1E]/8 shadow-md overflow-hidden max-w-4xl mx-auto">
        <div class="bg-[#0A0F1E] px-8 py-6 flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-[#4F46E5]">
              <span class="text-white font-black text-sm">SM</span>
            </div>
            <div>
              <h3 class="text-white font-bold text-xl">SEO Mandarin</h3>
              <a href="https://seomandarin.com" target="_blank" rel="noopener noreferrer"
                class="text-sm hover:underline flex items-center gap-1 transition-colors text-[#4F46E5]">
                seomandarin.com
                <!-- ExternalLink -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full border text-[#4F46E5]"
            style="background: rgba(79,70,229,0.133); border-color: rgba(79,70,229,0.333);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Campaign Complete
          </span>
        </div>

        <div class="p-8 lg:p-12">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase mb-3 text-[#64748B]">The Client</p>
              <p class="leading-relaxed text-[#64748B]">
                A specialist agency helping foreign brands advertise, grow, and sell in China. SEO Mandarin needed to build domain authority to compete for high-value search terms in a crowded niche dominated by established players.
              </p>
            </div>
            <div>
