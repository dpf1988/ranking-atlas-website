---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Ranking Atlas — Digital PR Agency | High-Authority Backlinks, No Retainer"
  description="A digital PR agency earning high-authority backlinks for SaaS, e-commerce, and tech brands through data-driven campaigns and expert commentary. No retainers, no contracts, minimum 8 links guaranteed per campaign."
>

  <!-- ── HERO ── -->
  <section id="home" class="pt-24 md:pt-28 lg:pt-32 pb-16 md:pb-20 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left column -->
        <div>
          <!-- H1 -->
          <h1 class="font-black leading-[1.08] tracking-tight mb-5 text-4xl sm:text-5xl lg:text-5xl xl:text-6xl">
            <span style="color: #5D4FE0;">Digital PR</span><span class="text-[#1a1a3a]"> Without The Retainer.</span>
          </h1>
          <!-- Subhead -->
          <p class="text-lg sm:text-xl leading-relaxed max-w-2xl mb-8 text-[#64748B]">
            We earn <span class="text-[#5D4FE0] font-semibold">high-authority backlinks</span> through data-driven campaigns and expert commentary. Pay only for results — minimum 8 links guaranteed.
          </p>
          <!-- Trust pills -->
          <div class="flex flex-wrap justify-start items-center gap-3 mb-8">
            {['8–12 Links Per Campaign', '100% Link Guarantee', 'No Retainers'].map(pill => (
              <div class="flex items-center gap-2 bg-white border border-[#5D4FE0]/20 rounded-full px-4 py-2 shadow-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="12" cy="12" r="12" fill="#5D4FE0"/>
                  <path d="M7 12.5l3.5 3.5 6.5-7" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                <span class="text-sm font-medium text-[#1a1a3a] whitespace-nowrap">{pill}</span>
              </div>
            ))}
          </div>
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contact"
              class="inline-flex items-center justify-center gap-2 bg-[#5D4FE0] hover:bg-[#4d41c8] text-white font-bold px-8 py-4 rounded-lg text-base transition-all duration-200 hover:-translate-y-0.5">
              Start a Campaign — $3.5K →
            </a>
            <a href="#services"
              class="inline-flex items-center justify-center gap-2 bg-white border-2 border-[#5D4FE0] text-[#5D4FE0] hover:bg-[#5D4FE0]/5 font-bold px-8 py-4 rounded-lg text-base transition-all duration-200 hover:-translate-y-0.5">
              See Methodology
            </a>
          </div>
        </div>

        <!-- Right column -->
        <div class="hidden lg:flex items-center justify-center">
          <!-- TODO: Replace with first case study visual -->
          <div class="w-full aspect-[4/5] max-h-[520px] bg-white rounded-2xl border border-[#0A0F1E]/8 shadow-sm flex items-center justify-center">
            <p class="text-[#64748B] text-sm font-medium">Case Study — Coming Soon</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PUBLICATIONS BAR ── -->
  <div class="border-y border-[#0A0F1E]/8 py-8 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-5">
      <p class="text-center text-xs font-semibold tracking-[0.2em] uppercase text-[#64748B]">
        We Target Publications Including
      </p>
    </div>
    <div class="relative overflow-hidden">
      <div class="flex items-center animate-scroll whitespace-nowrap">
        {['The Guardian', 'BBC', 'Forbes', 'Bloomberg', 'The Telegraph', 'Daily Mail', 'The Sun', 'New York Times',
          'The Guardian', 'BBC', 'Forbes', 'Bloomberg', 'The Telegraph', 'Daily Mail', 'The Sun', 'New York Times'].map((pub, i) => (
          <span class="inline-flex items-center shrink-0">
            <span class="font-semibold text-lg hover:text-[#0A0F1E] transition-colors px-10 text-[#0A0F1E]">
              {pub}
            </span>
            <span class="font-light shrink-0" style="color: rgba(79,70,229,0.3);">|</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ── SERVICES ── -->
  <section id="services" class="pt-10 pb-20 lg:pt-12 lg:pb-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl sm:text-5xl font-black mb-4 text-[#0A0F1E]">
          Our Digital PR Services
        </h2>
        <p class="text-xl max-w-2xl mx-auto text-[#64748B]">
          Three ways we get your brand featured in major publications.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Reactive PR -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- TrendingUp -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Reactive PR</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We monitor trending events, Google Trends, and breaking news to secure rapid link acquisition.</p>
          <ul class="space-y-2.5 mb-6">
            {['Google Trends monitoring', 'Breaking news response', 'Rapid link acquisition', 'Real-time pitching'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/reactive-pr.png" alt="Reactive PR example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

        <!-- Expert Commentary -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- MessageSquare -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Expert Commentary</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We position your brand as a thought leader by securing expert tips and insights in top-tier publications.</p>
          <ul class="space-y-2.5 mb-6">
            {['Thought leadership', 'Expert tips & insights', 'High-authority placements', 'Brand authority building'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/expert-pr.png" alt="Expert Commentary example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

        <!-- Data Campaigns -->
        <div class="bg-[#F1F5F9] rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110" style="background: rgba(79,70,229,0.094);">
            <!-- BarChart3 -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
              <path d="M18 20V10"/>
              <path d="M12 20V4"/>
              <path d="M6 20v-6"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0A0F1E]">Data Campaigns</h3>
          <p class="text-sm leading-relaxed mb-6 text-[#64748B]">We create original research stories using government statistics and proprietary datasets that generate high-authority backlinks at scale.</p>
          <ul class="space-y-2.5 mb-6">
            {['Government statistics', 'Proprietary data analysis', 'Original research stories', 'Scalable campaigns'].map(b => (
              <li class="flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="text-sm font-medium text-[#0A0F1E]">{b}</span>
              </li>
            ))}
          </ul>
          <img src="/data-campaign.png" alt="Data Campaigns example" class="w-full rounded-xl" style="box-shadow: 0 4px 16px rgba(10,15,30,0.12);" />
        </div>

      </div>
    </div>
  </section>

  <!-- ── GUARANTEES ── -->
  <section class="bg-[#0A0F1E] py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl sm:text-5xl font-black text-white mb-4">
          Digital PR with link guarantees
        </h2>
        <p class="text-xl max-w-2xl mx-auto text-[#64748B]">
          We run unlimited stories for you until link numbers are achieved.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- 100% Earned Links -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Award -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">100% Earned Links</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">Every link is genuinely earned through editorial placements — no paid inserts, ever.</p>
        </div>

        <!-- 100% Link Guarantee -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Shield -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">100% Link Guarantee</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">We run unlimited stories until your agreed link count is achieved.</p>
        </div>

        <!-- No Long-Term Contracts -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- FileText -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">No Long-Term Contracts</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">Campaign-by-campaign model. Stay because of results, not commitments.</p>
        </div>

        <!-- Highly Scalable -->
        <div class="text-center p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/[0.08] hover:border-[#4F46E5]/40 transition-all duration-300 group">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 transition-colors duration-300 group-hover:bg-[#4F46E5]" style="background: rgba(79,70,229,0.157);">
            <!-- Zap -->
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">Highly Scalable</h3>
          <p class="text-sm leading-relaxed text-[#64748B]">From 10 links to 80 — our process scales to match your growth ambitions.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CASE STUDY ── -->
  <section id="case-study" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl sm:text-5xl font-black mb-4 text-[#0A0F1E]">Case Study</h2>
        <p class="text-xl text-[#64748B]">Real results from a real client.</p>
      </div>

      <div class="bg-white rounded-3xl border border-[#0A0F1E]/8 shadow-md overflow-hidden max-w-4xl mx-auto">
        <div class="bg-[#0A0F1E] px-8 py-6 flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-[#4F46E5]">
              <span class="text-white font-black text-sm">SM</span>
            </div>
            <div>
              <h3 class="text-white font-bold text-xl">SEO Mandarin</h3>
              <a href="https://seomandarin.com" target="_blank" rel="noopener noreferrer"
                class="text-sm hover:underline flex items-center gap-1 transition-colors text-[#4F46E5]">
                seomandarin.com
                <!-- ExternalLink -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full border text-[#4F46E5]"
            style="background: rgba(79,70,229,0.133); border-color: rgba(79,70,229,0.333);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Campaign Complete
          </span>
        </div>

        <div class="p-8 lg:p-12">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase mb-3 text-[#64748B]">The Client</p>
              <p class="leading-relaxed text-[#64748B]">
                A specialist agency helping foreign brands advertise, grow, and sell in China. SEO Mandarin needed to build domain authority to compete for high-value search terms in a crowded niche dominated by established players.
              </p>
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase mb-3 text-[#64748B]">The Result</p>
              <p class="leading-relaxed text-[#64748B]">
                Two campaigns delivered enough high-authority earned backlinks to move SEO Mandarin from the third page of Google to positions 3–4 for their most competitive search terms — in under two months. The increased visibility led directly to a client worth over $100,000 per year, turning a $7,000 digital PR investment into a 14x return within twelve months.
              </p>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-4">
            {[
              { label: 'Google Rankings',      value: 'Page 3 → Top 5' },
              { label: 'Return on Investment', value: '14x'            },
              { label: 'Link Guarantee Met',   value: '100%'           },
            ].map(s => (
              <div class="bg-[#F1F5F9] border border-[#0A0F1E]/8 rounded-xl px-6 py-4 text-center">
                <p class="text-2xl font-black text-[#0A0F1E]">{s.value}</p>
                <p class="text-xs font-medium mt-1 text-[#64748B]">{s.label}</p>
              </div>
            ))}
          </div>

          <div class="mt-8">
            <a href="https://seomandarin.com" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-semibold transition-colors hover:opacity-80 text-[#4F46E5]">
              View Website
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA SECTION ── -->
  <section class="bg-[#0A0F1E] py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl font-black text-white mb-5 leading-tight">
        Start Digital PR with Ranking Atlas
      </h2>
      <p class="text-xl mb-10 max-w-xl mx-auto text-[#64748B]">
        $3.5K per campaign. Minimum 8 links guaranteed. No long-term contracts.
      </p>
      <a href="#contact"
        class="inline-flex items-center gap-2 bg-[#4F46E5] hover:bg-[#4338CA] text-white font-bold px-10 py-4 rounded-xl text-base transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_20px_4px_rgba(245,197,24,0.35)]">
        Launch a Campaign – $3.5K
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <Contact />

  <!-- ── FAQ ── -->
  <FAQ />

</Layout>

<script>
  // Smooth scroll to hash on page load
  const hash = window.location.hash;
  if (hash) {
    const el = document.querySelector(hash);
    if (el) {
      setTimeout(() => el.scrollIntoView({ behavior: 'smooth' }), 100);
    }
  }
</script>
