---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import PrimaryCTA from '../components/PrimaryCTA.astro';
import SecondaryCTA from '../components/SecondaryCTA.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { DollarSign, CheckCircle, Receipt, Tag, ShieldCheck, Calendar, LineChart, FileText, CreditCard, Bot, ExternalLink, TrendingUp, Newspaper, FlaskConical } from 'lucide-astro';
---

<Layout
  title="Ranking Atlas — Citation Equity for B2B SaaS Brands"
  description="Editorial PR campaigns that get B2B SaaS brands cited by the publishers AI systems trust. Per-campaign, fixed price, guaranteed minimum placements."
>

  <!-- ── 1. HERO ── -->
  <section id="home" class="relative overflow-hidden pt-20 md:pt-24 lg:pt-28 pb-16 md:pb-16 lg:pb-20">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/4 w-[700px] h-[700px] rounded-full opacity-[0.10] blur-[140px]"
           style="background: radial-gradient(circle, #5D4FE0 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: text -->
        <div>
          <Eyebrow label="Citation equity for B2B SaaS" />
          <h1 class="font-black leading-[1.08] tracking-tighter mb-5 text-4xl sm:text-5xl lg:text-[56px]">
            <span class="text-[#0A0F1E]">Be the brand </span><span class="relative inline-block pb-2 pr-1"><span style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">AI cites</span><svg viewBox="0 0 200 12" preserveAspectRatio="none" class="absolute -bottom-1 left-0 w-full h-3 text-[#5D4FE0]" aria-hidden="true"><path d="M2 8 Q 50 2, 100 6 T 198 5" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/></svg></span>
          </h1>
          <p class="text-lg leading-relaxed mb-6 text-[#475569]">
            When buyers ask ChatGPT, Perplexity, or Gemini who to trust, those systems favour authoritative domains. We build that authority through high-quality editorial links — so your site is more likely to be cited.
          </p>
          <div class="flex flex-wrap items-center gap-3 mb-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <CheckCircle size={16} class="text-[#5D4FE0] shrink-0" />
              8+ high-authority editorial links
            </div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <DollarSign size={16} class="text-[#5D4FE0] shrink-0" />
              Fixed $3.5K campaign
            </div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <Receipt size={16} class="text-[#5D4FE0] shrink-0" />
              No retainers
            </div>
          </div>
          <div class="flex flex-wrap gap-3">
            <SecondaryCTA href="#placements-section" label="See placements" />
            <PrimaryCTA href="/contact" label="Start campaign — $3.5K →" />
          </div>
        </div>

        <!-- Right: publication screenshot placeholder card -->
        <div class="hidden lg:flex justify-center">
          <div class="bg-white rounded-2xl shadow-[0_20px_60px_-15px_rgba(10,15,30,0.2)] border border-[#0A0F1E]/8 overflow-hidden max-w-md w-full">
            <!-- Fake browser chrome -->
            <div class="flex items-center gap-1.5 px-4 py-3 bg-[#F1F5F9] border-b border-[#0A0F1E]/8">
              <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
              <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
              <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
              <div class="flex-1 ml-2 bg-white rounded px-3 py-1 text-xs text-[#94A3B8] font-mono truncate">theguardian.com/business/...</div>
            </div>
            <!-- Dark headline strip -->
            <div class="bg-[#0A0F1E] px-5 py-4">
              <p class="text-sm font-bold text-white leading-snug mb-1">How AI is reshaping B2B brand authority</p>
              <p class="text-xs text-[#64748B]">The Guardian · Business · Technology</p>
            </div>
            <!-- Placeholder image area -->
            <div class="aspect-video bg-[#F1F5F9] flex items-center justify-center">
              <span class="text-xs text-[#CBD5E1] font-medium">[Publication article placeholder]</span>
            </div>
            <!-- Skeleton text lines -->
            <div class="p-5 space-y-3">
              <div class="h-3 bg-[#F1F5F9] rounded-full w-full"></div>
              <div class="h-3 bg-[#F1F5F9] rounded-full w-5/6"></div>
              <div class="h-3 bg-[#F1F5F9] rounded-full w-4/6"></div>
              <div class="h-3 bg-[#F1F5F9] rounded-full w-3/6"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 2. PUBLISHER PILLS STRIP ── -->
  <div class="bg-white py-8 border-y border-[#0A0F1E]/8">
    <div class="max-w-6xl mx-auto px-6 mb-8">
      <p class="text-center text-xs uppercase tracking-[0.2em] font-semibold text-[#64748B]">Publishers we have placed clients on</p>
    </div>
    <div class="relative overflow-hidden w-full">
      <!-- Left fade -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <!-- Right fade -->
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
      <!-- Scrolling track (duplicated for seamless loop) -->
      <div class="flex gap-3 animate-marquee-slow whitespace-nowrap w-max">
        <!-- First copy -->
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Telegraph</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">BBC</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Guardian</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Daily Mail</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Sun</span>
        <!-- Duplicate for seamless loop -->
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Telegraph</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">BBC</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Guardian</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Daily Mail</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The Sun</span>
      </div>
    </div>
  </div>

  <!-- ── 3. WHAT YOU GET ── -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4 pb-1" style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">What AI systems trust</h2>
        <p class="text-lg text-[#64748B] max-w-3xl mx-auto">Domain authority and omnipresence across authoritative publishers is the pattern LLMs and Google use to decide which brands to surface. Earning that pattern is increasingly a matter of originating stories worth covering.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Card 1: Authority + omnipresence -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <TrendingUp size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-2xl font-bold text-[#5D4FE0] mb-4">Authority + omnipresence</h3>
          <p class="text-base text-[#475569] leading-relaxed">Domain authority and repeated mentions across trusted publishers form the pattern LLMs and search engines use to decide who to cite. One mention doesn't move visibility. Consistent coverage across authority sources does.</p>
        </div>

        <!-- Card 2: Editorial citations -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <Newspaper size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-2xl font-bold text-[#5D4FE0] mb-4">Editorial citations</h3>
          <p class="text-base text-[#475569] leading-relaxed">Mentions in authoritative editorial publications — not self-published content — are what build the pattern. The brands surfaced by ChatGPT, Perplexity, Gemini, and Google AI Overviews are the ones with broad editorial coverage.</p>
        </div>

        <!-- Card 3: Data-led research -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <FlaskConical size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-2xl font-bold text-[#5D4FE0] mb-4">Data-led research</h3>
          <p class="text-base text-[#475569] leading-relaxed">Getting authority publishers to cite you increasingly requires giving journalists stories worth covering. Ranking Atlas runs data-led campaigns — original research, proprietary data, industry studies — that earn those citations.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 4. HOW RANKING ATLAS WORKS ── -->
  <section class="relative overflow-hidden py-16 lg:py-24" style="background: #5D4FE0;">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22/></filter><rect width=%22100%22 height=%22100%22 filter=%22url(%23n)%22/></svg>');"></div>
    <div class="relative max-w-6xl mx-auto px-6 text-center">
      <div class="mb-12">
        <Eyebrow label="How it works" variant="dark" />
        <h2 class="text-4xl md:text-5xl font-black text-white leading-tight tracking-tight mb-4">Everything you need, nothing you don't.</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">A fixed-scope campaign that earns citations on the publishers AI systems trust — with measurement proving it worked.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <Tag size={22} class="text-white" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3">One price, on the page</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign is fixed-scope and fixed-price, starting at $3.5K. No hidden tiers, no retainer pitch, no surprises at invoice time.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <ShieldCheck size={22} class="text-white" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Placements, guaranteed</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign commits to a minimum number of placements on authority publishers. If we don't hit it, we keep working until we do.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <Calendar size={22} class="text-white" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Campaign windows, not contracts</h3>
          <p class="text-sm text-white/70 leading-relaxed">Engagements are defined by a campaign, not a month. Book one when you need coverage. Leave when you don't.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <LineChart size={22} class="text-white" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Proof of visibility</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign includes before-and-after measurement across ChatGPT, Perplexity, Gemini, and Google AI Overviews. You see exactly what the coverage produced.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 5. SOME OF OUR PLACEMENTS ── -->
  <section id="placements-section" class="py-16 lg:py-24" style="background: #F8F7FA;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4 pb-1" style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Some of our placements</h2>
        <p class="text-lg text-[#64748B]">Real coverage earned across our background work in B2B SaaS.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        {[
          { domain: 'theguardian.com', title: 'How fintech brands are building trust through editorial credibility' },
          { domain: 'forbes.com',      title: 'The new B2B SaaS playbook for AI-era brand visibility' },
          { domain: 'bloomberg.com',   title: 'Inside the citation patterns shaping AI search results' },
          { domain: 'telegraph.co.uk', title: 'Why authority publishers are the new SEO' },
          { domain: 'nytimes.com',     title: 'How buyers are using ChatGPT to research vendors' },
          { domain: 'thesun.co.uk',    title: 'The privacy startups redefining data trust' },
        ].map(card => (
          <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
            <div class="px-4 py-2.5 bg-[#F8F7FA] border-b border-[#0A0F1E]/8 flex items-center gap-2">
              <div class="w-4 h-4 rounded-sm bg-[#5D4FE0]/30 shrink-0"></div>
              <span class="text-xs font-medium text-[#64748B] truncate">{card.domain}</span>
            </div>
            <div class="aspect-video bg-[#F1F5F9] flex items-center justify-center">
              <span class="text-xs text-[#CBD5E1] font-medium">[Article screenshot placeholder]</span>
            </div>
            <div class="p-4">
              <p class="text-sm font-bold text-[#0A0F1E] leading-snug">{card.title}</p>
            </div>
          </div>
        ))}

      </div>
      <div class="mt-12 flex flex-wrap gap-3 justify-center">
        <PrimaryCTA href="/contact" />
        <SecondaryCTA href="/ai-search-visibility" label="How AI search picks sources" />
      </div>
    </div>
  </section>

  <!-- ── 6. COMPOUND ── -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <Eyebrow label="Why it matters now" />
        <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4 pb-1" style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Editorial citations compound what you're already running.</h2>
        <p class="text-lg text-[#64748B] max-w-3xl mx-auto">Content needs external authority to rank — in search engines and in LLMs. As paid ads eat further into organic results, LLM visibility is becoming a vital acquisition channel. Editorial citations are what get your brand cited.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <FileText size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg font-bold text-[#0A0F1E] mb-3">Content needs the authority signal</h3>
          <p class="text-base text-[#475569] leading-relaxed"><a href="https://ahrefs.com/blog/search-traffic-study/" target="_blank" rel="noopener noreferrer" class="text-[#5D4FE0] hover:text-[#4338CA] underline underline-offset-2 decoration-[#5D4FE0]/30 hover:decoration-[#5D4FE0] transition-colors">Ahrefs</a> found 90.63% of pages get zero organic traffic from Google — the most common reason is a lack of inbound links from trusted sources. Editorial citations are the authority signal search engines and LLMs look for.</p>
        </div>

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <CreditCard size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg font-bold text-[#0A0F1E] mb-3">Paid is compensating for shrinking organic</h3>
          <p class="text-base text-[#475569] leading-relaxed"><a href="https://www.dataslayer.ai/blog/google-ai-overviews-the-end-of-traditional-ctr-and-how-to-adapt-in-2025" target="_blank" rel="noopener noreferrer" class="text-[#5D4FE0] hover:text-[#4338CA] underline underline-offset-2 decoration-[#5D4FE0]/30 hover:decoration-[#5D4FE0] transition-colors">Seer Interactive</a> found organic CTR dropped 61% on queries where an AI Overview appeared. That spend shifts into paid — but the brands AI cites still win the click. Editorial coverage is what puts you in the cited set.</p>
        </div>

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <Bot size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg font-bold text-[#0A0F1E] mb-3">AI search is where buyers now research vendors</h3>
