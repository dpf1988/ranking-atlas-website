---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import PrimaryCTA from '../components/PrimaryCTA.astro';
import SecondaryCTA from '../components/SecondaryCTA.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { DollarSign, CheckCircle, Receipt, Tag, ShieldCheck, Calendar, LineChart, FileText, CreditCard, Bot, ExternalLink, TrendingUp, Newspaper, FlaskConical } from 'lucide-astro';
---

<Layout
  title="Ranking Atlas — Citation Equity for B2B SaaS Brands"
  description="Editorial PR campaigns that get B2B SaaS brands cited by the publishers AI systems trust. Per-campaign, fixed price, guaranteed minimum placements."
>

  <!-- ── 1. HERO ── -->
  <section id="home" class="relative overflow-hidden pt-20 md:pt-24 lg:pt-28 pb-16 md:pb-16 lg:pb-20">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/4 w-[700px] h-[700px] rounded-full opacity-[0.10] blur-[140px]"
           style="background: radial-gradient(circle, #5D4FE0 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">

        <!-- Text -->
          <Eyebrow label="Citation equity for B2B SaaS" />
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-ink leading-[1.1] mb-5">
            <span class="text-[#0A0F1E]">Be the Brand </span><span class="relative inline-block pb-2 pr-1"><span style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">AI Cites</span><svg viewBox="0 0 200 12" preserveAspectRatio="none" class="absolute -bottom-1 left-0 w-full h-3 text-[#5D4FE0]" aria-hidden="true"><path d="M2 8 Q 50 2, 100 6 T 198 5" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/></svg></span>
          </h1>
          <p class="text-lg leading-relaxed mb-6 text-[#475569]">
            AI systems cite authoritative publishers.<br />
            Editorial coverage builds that authority.<br />
            We earn it for you.
          </p>
          <div class="flex flex-wrap justify-center items-center gap-3 mb-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <CheckCircle size={16} class="text-[#5D4FE0] shrink-0" />
              8+ placements on authority publishers
            </div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <DollarSign size={16} class="text-[#5D4FE0] shrink-0" />
              Fixed $3.5K campaign
            </div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#0A0F1E]/8 shadow-[0_2px_8px_-2px_rgba(10,15,30,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_-4px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/30 text-sm font-medium text-[#0A0F1E]">
              <Receipt size={16} class="text-[#5D4FE0] shrink-0" />
              No retainers
            </div>
          </div>
          <div class="flex flex-wrap justify-center gap-3">
            <PrimaryCTA href="/contact" />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 2. PUBLISHER PILLS STRIP ── -->
  <div class="bg-white py-8 border-y border-[#0A0F1E]/8">
    <div class="max-w-6xl mx-auto px-6 mb-8">
      <p class="text-center text-xs uppercase tracking-[0.2em] font-semibold text-[#64748B]">Publishers We Target</p>
    </div>
    <div class="relative overflow-hidden w-full">
      <!-- Left fade -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <!-- Right fade -->
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
      <!-- Scrolling track (duplicated for seamless loop) -->
      <div class="flex gap-3 animate-marquee-slow whitespace-nowrap w-max">
        <!-- First copy -->
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">TechCrunch</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Wired</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Financial Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Ars Technica</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">VentureBeat</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Dark Reading</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">SecurityWeek</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">American Banker</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Fintech Futures</span>
        <!-- Duplicate for seamless loop -->
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Forbes</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Bloomberg</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">The New York Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">TechCrunch</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Wired</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Financial Times</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Ars Technica</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">VentureBeat</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Dark Reading</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">SecurityWeek</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">American Banker</span>
        <span class="px-5 py-2.5 rounded-full border border-[#0A0F1E]/10 bg-white text-sm font-semibold text-[#0A0F1E] whitespace-nowrap shrink-0">Fintech Futures</span>
      </div>
    </div>
  </div>

  <!-- ── 3. WHAT YOU GET ── -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4 pb-1" style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">What AI Systems Trust</h2>
        <p class="text-lg text-[#64748B] max-w-3xl mx-auto">Publisher authority and omnipresence across authoritative sources are the pattern LLMs and Google use to decide which brands to surface. Earning that pattern means originating stories worth covering.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Card 1: Authority + Omnipresence -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <TrendingUp size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-[#5D4FE0] leading-snug mb-3">Authority + Omnipresence</h3>
          <p class="text-base text-[#475569] leading-relaxed">Publisher authority and repeated mentions across trusted publishers form the pattern LLMs and search engines use to decide who to cite. One mention doesn't move visibility. Consistent coverage across authority sources does.</p>
        </div>

        <!-- Card 2: Editorial citations -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <Newspaper size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-[#5D4FE0] leading-snug mb-3">Editorial Citations</h3>
          <p class="text-base text-[#475569] leading-relaxed">Self-published content does not build the pattern. Editorial mentions on authority publishers do. The brands surfaced in ChatGPT, Perplexity, Gemini, and Google AI Overviews are the ones with broad editorial coverage.</p>
        </div>

        <!-- Card 3: Data-Led Research -->
        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <FlaskConical size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-[#5D4FE0] leading-snug mb-3">Data-Led Research</h3>
          <p class="text-base text-[#475569] leading-relaxed">Authority publishers cite stories, not brands. Ranking Atlas runs data-led campaigns that give journalists something to cover: original research, proprietary data, industry studies. That is what earns the citations.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 4. HOW RANKING ATLAS WORKS ── -->
  <section class="relative overflow-hidden py-16 lg:py-24" style="background: #5D4FE0;">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22/></filter><rect width=%22100%22 height=%22100%22 filter=%22url(%23n)%22/></svg>');"></div>
    <div class="relative max-w-6xl mx-auto px-6 text-center">
      <div class="mb-12">
        <Eyebrow label="How it works" variant="dark" />
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight mb-4">Everything You Need, Nothing You Don't.</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Fixed-scope campaigns. Citations on the publishers AI trusts. Measurement that proves it worked.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <Tag size={22} class="text-white" />
          </div>
          <h3 class="text-base md:text-lg font-semibold tracking-tight text-white leading-snug mb-3">One Price, on the Page</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign is fixed-scope and fixed-price, starting at $3.5K. No hidden tiers, no retainer pitch, no surprises at invoice time.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <ShieldCheck size={22} class="text-white" />
          </div>
          <h3 class="text-base md:text-lg font-semibold tracking-tight text-white leading-snug mb-3">Placements, Guaranteed</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign commits to a minimum number of placements on authority publishers. If we don't hit it, we keep working until we do.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <Calendar size={22} class="text-white" />
          </div>
          <h3 class="text-base md:text-lg font-semibold tracking-tight text-white leading-snug mb-3">Campaign Windows, Not Contracts</h3>
          <p class="text-sm text-white/70 leading-relaxed">Engagements are defined by a campaign, not a month. Book one when you need coverage. Leave when you don't.</p>
        </div>

        <div class="relative bg-white/[0.06] backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-left transition-all duration-300 hover:bg-white/[0.09] hover:border-white/20 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <LineChart size={22} class="text-white" />
          </div>
          <h3 class="text-base md:text-lg font-semibold tracking-tight text-white leading-snug mb-3">Proof of Visibility</h3>
          <p class="text-sm text-white/70 leading-relaxed">Every campaign includes before-and-after measurement across ChatGPT, Perplexity, Gemini, and Google AI Overviews. You see exactly what the coverage produced.</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ── 6. COMPOUND ── -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <Eyebrow label="Why it matters now" />
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4 pb-1" style="background: linear-gradient(135deg, #5D4FE0 0%, #7C3AED 50%, #4338CA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Editorial Citations Compound What You're Already Running.</h2>
        <p class="text-lg text-[#64748B] max-w-3xl mx-auto">Content needs external authority to rank. In search. In LLMs. Paid ads are eating organic results, which makes LLM visibility a primary acquisition channel. Editorial citations are what put you in the cited set.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <FileText size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-ink leading-snug mb-3">Content Needs the Authority Signal</h3>
          <p class="text-base text-[#475569] leading-relaxed"><a href="https://ahrefs.com/blog/search-traffic-study/" target="_blank" rel="noopener noreferrer" class="text-[#5D4FE0] hover:text-[#4338CA] underline underline-offset-2 decoration-[#5D4FE0]/30 hover:decoration-[#5D4FE0] transition-colors">Ahrefs</a> found 90.63% of pages get zero organic traffic from Google. The most common reason: no inbound coverage from trusted sources. Editorial citations are the authority signal search engines and LLMs look for.</p>
        </div>

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <CreditCard size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-ink leading-snug mb-3">Paid Is Compensating for Shrinking Organic</h3>
          <p class="text-base text-[#475569] leading-relaxed"><a href="https://www.dataslayer.ai/blog/google-ai-overviews-the-end-of-traditional-ctr-and-how-to-adapt-in-2025" target="_blank" rel="noopener noreferrer" class="text-[#5D4FE0] hover:text-[#4338CA] underline underline-offset-2 decoration-[#5D4FE0]/30 hover:decoration-[#5D4FE0] transition-colors">Seer Interactive</a> found organic CTR dropped 61% on queries where an AI Overview appeared. Budget shifts into paid. The brands AI cites still win the click. Editorial coverage is what puts you there.</p>
        </div>

        <div class="bg-white rounded-2xl border border-[#0A0F1E]/8 p-8 shadow-[0_4px_20px_-8px_rgba(10,15,30,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-8px_rgba(93,79,224,0.2)] hover:border-[#5D4FE0]/20">
          <div class="w-12 h-12 rounded-xl bg-[#5D4FE0]/10 flex items-center justify-center mb-6">
            <Bot size={22} class="text-[#5D4FE0]" />
          </div>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-ink leading-snug mb-3">AI Search Is Where Buyers Now Research Vendors</h3>
          <p class="text-base text-[#475569] leading-relaxed"><a href="https://digitalcontentnext.org/blog/2025/05/06/googles-ai-overviews-linked-to-lower-publisher-clicks/" target="_blank" rel="noopener noreferrer" class="text-[#5D4FE0] hover:text-[#4338CA] underline underline-offset-2 decoration-[#5D4FE0]/30 hover:decoration-[#5D4FE0] transition-colors">Digital Content Next</a> reported Google referral traffic fell 10% year-over-year in 2025, 14% for non-news brands. That intent is moving to ChatGPT, Perplexity, and Gemini. The brands surfaced in those answers are the ones with broad editorial coverage.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 7. FAQ ── -->
  <FAQ />

  <!-- ── 8. FINAL PURPLE CTA BAND ── -->
  <section class="relative overflow-hidden py-16 lg:py-24 text-center" style="background: #5D4FE0;">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22/></filter><rect width=%22100%22 height=%22100%22 filter=%22url(%23n)%22/></svg>');"></div>
    <div class="relative max-w-4xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1] mb-6">
        Be the Brand <span class="relative inline-block pb-2">AI Cites<svg viewBox="0 0 200 12" preserveAspectRatio="none" class="absolute -bottom-1 left-0 w-full h-3" aria-hidden="true"><path d="M2 8 Q 50 2, 100 6 T 198 5" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/></svg></span>.
      </h2>
      <p class="text-lg text-white/80 mb-10">Per-campaign. Fixed price. Guaranteed placements on authority publishers.</p>
      <a href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-white text-[#5D4FE0] font-bold text-base hover:bg-white/95 transition-all duration-200 hover:-translate-y-0.5 shadow-[0_8px_30px_-8px_rgba(0,0,0,0.3)]">
        Start a Campaign — $3.5K →
      </a>
    </div>
  </section>

</Layout>

<script>
  const hash = window.location.hash;
  if (hash) {
    const el = document.querySelector(hash);
    if (el) {
      setTimeout(() => el.scrollIntoView({ behavior: 'smooth' }), 100);
    }
  }
</script>
