---
import LibraryLayout from '../../layouts/LibraryLayout.astro';
import libraryData from '../../data/library.json';

export function getStaticPaths() {
  return libraryData.map((campaign) => ({
    params: { slug: campaign.slug },
    props: { campaign },
  }));
}

interface Campaign {
  slug: string;
  title: string;
  date: string;
  subtitle: string;
  findings: string[];
  press_release_body: string;
  quote: string;
  methodology: string;
  sources: { name: string; url: string }[];
  asset_downloads: string[];
  // Optional newsroom fields
  attribution_line?: string;
  standfirst?: string;
  summary?: string[];
  dataset_label?: string;
}

const { campaign } = Astro.props as { campaign: Campaign };

function toISODateTime(dateStr: string): string {
  if (/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return `${dateStr}T00:00:00+00:00`;
  return dateStr;
}

function formatDate(dateStr: string): string {
  const [year, month, day] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

function formatMonthYear(dateStr: string): string {
  const [year, month] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, 1).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long',
  });
}

// --- Block parser ---

type ContentBlock =
  | { type: 'paragraph'; text: string }
  | { type: 'table'; headers: string[]; rows: string[][] };

function parseCells(line: string): string[] {
  return line.split('|').slice(1, -1).map((c) => c.trim());
}

function isDividerRow(line: string): boolean {
  return /^\|[\s\-|]+\|$/.test(line.trim());
}

function parseContentBlock(block: string): ContentBlock {
  const trimmed = block.trim();
  if (!trimmed.startsWith('|')) return { type: 'paragraph', text: trimmed };
  const lines = trimmed.split('\n').map((l) => l.trim()).filter(Boolean);
  const contentLines = lines.filter((l) => !isDividerRow(l));
  if (contentLines.length < 1) return { type: 'paragraph', text: trimmed };
  const [headerLine, ...dataLines] = contentLines;
  return {
    type: 'table',
    headers: parseCells(headerLine),
    rows: dataLines.map(parseCells),
  };
}

// --- Render item list: inject quote after 2nd paragraph, dataset label before tables ---

type RenderItem =
  | ContentBlock
  | { type: 'quote_injection' }
  | { type: 'dataset_label_injection' };

const rawBlocks = campaign.press_release_body.split(/\n\n+/).map(parseContentBlock);
const renderItems: RenderItem[] = [];
let paragraphCount = 0;

for (const block of rawBlocks) {
  if (block.type === 'table' && campaign.dataset_label) {
    renderItems.push({ type: 'dataset_label_injection' });
  }
  renderItems.push(block);
  if (block.type === 'paragraph') {
    paragraphCount++;
    if (paragraphCount === 2 && campaign.quote) {
      renderItems.push({ type: 'quote_injection' });
    }
  }
}

// --- YouGov linkifier ---

const YOUGOV_URL = 'https://yougov.com/en-gb/ratings/national-and-religious-events';
function linkifyYouGov(text: string): string {
  return text.replace(
    /YouGov/g,
    `<a href="${YOUGOV_URL}" class="inline-link" target="_blank" rel="noopener">YouGov</a>`
  );
}

const citationString = `Ranking Atlas. "${campaign.title}." ranking-atlas.com/library/${campaign.slug}. Published ${formatMonthYear(campaign.date)}.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Report",
  "headline": campaign.title,
  "description": campaign.subtitle,
  "url": `https://ranking-atlas.com/library/${campaign.slug}`,
  "datePublished": toISODateTime(campaign.date),
  "author": {
    "@type": "Person",
    "name": "Daniel Grainger",
    "url": "https://ranking-atlas.com/about",
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com",
    },
  },
  "publisher": {
    "@type": "Organization",
    "name": "Ranking Atlas",
    "url": "https://ranking-atlas.com",
  },
};
---

<LibraryLayout
  title={`${campaign.title}: Ranking Atlas Library`}
  description={campaign.subtitle}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="text-sm text-muted mb-6 flex flex-wrap items-center gap-1">
    <a href="/library" class="inline-link">Library</a>
    <span class="mx-1">/</span>
    <span>{campaign.title}</span>
  </nav>

  <!-- Date -->
  <p class="text-sm text-muted mb-4">Published {formatDate(campaign.date)}</p>

  <!-- H1 -->
  <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-4">
    {campaign.title}
  </h1>

  <!-- Attribution line -->
  {campaign.attribution_line && (
    <p class="text-sm text-muted italic mb-6">{campaign.attribution_line}</p>
  )}

  <!-- Standfirst (falls back to subtitle if absent) -->
  {campaign.standfirst ? (
    <p class="text-lg md:text-xl text-ink font-medium leading-relaxed mb-10" set:html={linkifyYouGov(campaign.standfirst)} />
  ) : (
    <p class="text-lg md:text-xl text-muted leading-relaxed mb-10" set:html={linkifyYouGov(campaign.subtitle)} />
  )}

  <!-- Key Findings -->
  <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mt-10 mb-4">Key Findings</h2>
  <ul class="list-disc pl-5 space-y-2 text-body leading-relaxed mb-10">
    {campaign.findings.map((finding) => (
      <li>{finding}</li>
    ))}
  </ul>

  <!-- Summary for attribution -->
  {campaign.summary && campaign.summary.length > 0 && (
    <div class="bg-surface border-l-4 border-brand rounded-r-xl p-6 my-10">
      <p class="text-sm font-semibold text-ink mb-3">Summary for attribution:</p>
      <ul class="space-y-2 text-body list-disc pl-5">
        {campaign.summary.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  )}

  <!-- Press Release -->
  <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mt-10 mb-4">Press Release</h2>
  <div class="space-y-4 text-body leading-relaxed mb-10">
    {renderItems.map((item) => {
      if (item.type === 'quote_injection') {
        return (
          <blockquote class="border-l-4 border-brand bg-white rounded-r-xl pl-5 pr-4 py-4 my-6 shadow-card">
            <p class="text-body leading-relaxed italic">"{campaign.quote}"</p>
            <p class="text-sm text-muted mt-2">— Daniel Grainger, Founder, Ranking Atlas</p>
          </blockquote>
        );
      }
      if (item.type === 'dataset_label_injection') {
        return (
          <p class="text-sm uppercase tracking-wider text-brand font-medium mb-3 mt-6">
            {campaign.dataset_label}
          </p>
        );
      }
      if (item.type === 'table') {
        return (
          <div class="overflow-x-auto my-2">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr>
                  {item.headers.map((h) => (
                    <th class="text-left text-xs uppercase tracking-wider text-muted font-medium px-4 py-2 bg-surface border border-[#0A0F1E]/8 whitespace-nowrap">
                      {h}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {item.rows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td class="px-4 py-2 text-body border border-[#0A0F1E]/8">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      }
      return <p>{item.text}</p>;
    })}
  </div>

  <!-- Methodology -->
  <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mt-10 mb-4">Methodology</h2>
  <p class="text-body leading-relaxed mb-10" set:html={linkifyYouGov(campaign.methodology)} />

  <!-- Sources -->
  {campaign.sources.length > 0 && (
    <div>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mt-10 mb-4">Sources</h2>
      <ul class="list-disc pl-5 space-y-2 mb-10">
        {campaign.sources.map((source) => (
          <li>
            <a href={source.url} class="inline-link" target="_blank" rel="noopener">{source.name}</a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Notes to editors -->
  <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mt-10 mb-4">Notes to Editors</h2>
  <p class="text-body leading-relaxed mb-10">
    Ranking Atlas runs fixed-price editorial PR campaigns for B2B SaaS brands, building citation equity through coverage on authority publishers. For interviews, additional data requests, or press enquiries, contact <a href="mailto:contact@ranking-atlas.com" class="inline-link">contact@ranking-atlas.com</a>.
  </p>

  <!-- Cite this research -->
  <div class="bg-white border border-[#0A0F1E]/8 rounded-xl p-6 shadow-card mt-12 mb-8">
    <p class="text-sm font-semibold text-ink mb-3">Cite This Research</p>
    <p id="citation-text" class="text-sm text-body leading-relaxed font-mono mb-4">{citationString}</p>
    <button
      id="copy-citation"
      class="text-sm text-brand hover:text-brand-dark font-medium transition-colors"
      data-citation={citationString}
    >
      Copy citation
    </button>
  </div>
  <script is:inline>
    const btn = document.getElementById('copy-citation');
    if (btn) {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-citation') ?? '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy citation'; }, 2000);
        });
      });
    }
  </script>

  <!-- Press contact -->
  <p class="text-sm text-muted">
    <span class="font-medium text-ink">Press contact:</span>{' '}
    <a href="mailto:contact@ranking-atlas.com" class="inline-link">contact@ranking-atlas.com</a>
  </p>
</LibraryLayout>
