---
import LibraryLayout from '../../layouts/LibraryLayout.astro';
import libraryData from '../../data/library.json';

function toISODateTime(dateStr: string): string {
  if (/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return `${dateStr}T00:00:00+00:00`;
  return dateStr;
}

function formatDate(dateStr: string): string {
  const [year, month, day] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric',
  });
}

// Sort descending by date
const sorted = [...libraryData].sort((a, b) => b.date.localeCompare(a.date));

// Group by year
const byYear = new Map<number, typeof sorted>();
for (const entry of sorted) {
  const year = Number(entry.date.split('-')[0]);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(entry);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Ranking Atlas Library",
  "description": "Press archive. Research and data campaigns issued by Ranking Atlas.",
  "url": "https://ranking-atlas.com/library/",
  "itemListElement": sorted.map((entry, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Report",
      "headline": entry.title,
      "url": `https://ranking-atlas.com/library/${entry.slug}`,
      "datePublished": toISODateTime(entry.date),
    },
  })),
};
---

<LibraryLayout
  title="Library — Ranking Atlas"
  description="Press archive. Research and data campaigns issued by Ranking Atlas."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-6">
    Library
  </h1>

  <p class="text-lg md:text-xl text-body leading-relaxed mb-10">
    Press archive. Research and data campaigns issued by Ranking Atlas. For press enquiries:{' '}
    <a href="mailto:contact@ranking-atlas.com" class="inline-link">contact@ranking-atlas.com</a>
  </p>

  {years.map((year) => (
    <div>
      <h2 class="text-xl font-medium text-muted mt-12 mb-4">{year}</h2>
      <div>
        {byYear.get(year)!.map((entry, i, arr) => (
          <a
            href={`/library/${entry.slug}/`}
            class:list={[
              'flex items-baseline gap-4 py-3 group transition-colors',
              i < arr.length - 1 ? 'border-b border-[#0A0F1E]/8' : '',
            ]}
          >
            <span class="shrink-0 w-20 text-sm text-muted tabular-nums">
              {formatDate(entry.date)}
            </span>
            <span class="text-ink group-hover:text-brand transition-colors leading-snug">
              {entry.title}
            </span>
          </a>
        ))}
      </div>
    </div>
  ))}
</LibraryLayout>
