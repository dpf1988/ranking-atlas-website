---
import Layout from '../../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Research and Analysis for B2B SaaS Marketing Teams",
  "url": "https://ranking-atlas.com/resources/",
  "author": {
    "@type": "Person",
    "name": "Daniel Grainger",
    "url": "https://ranking-atlas.com/about",
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com"
    },
    "sameAs": [
      "https://www.linkedin.com/in/daniel-grainger/",
      "https://ranking-atlas.com/about"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Ranking Atlas",
    "url": "https://ranking-atlas.com"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Article",
          "headline": "AI Search Visibility: How ChatGPT, Perplexity, and Gemini Choose Which Brands to Cite",
          "description": "How ChatGPT, Perplexity, Google AI Overviews, and Gemini choose which brands to mention. Citation equity is what puts you in the answer.",
          "url": "https://ranking-atlas.com/resources/ai-search-visibility",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-04-12",
          "dateModified": "2026-04-13"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Article",
          "headline": "The Cost of Authority: 2026 Backlink Pricing Index",
          "description": "Primary-source pricing data across 140,000+ publisher listings and six years of agency snapshots. What backlinks cost, how pricing has moved 2020–2026, and why the market is solving the wrong problem.",
          "url": "https://ranking-atlas.com/resources/the-cost-of-authority",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-03-01",
          "dateModified": "2026-04-01"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Article",
          "headline": "Citation Equity vs Link Building: Why the Old Playbook Stops Working",
          "description": "Link-building was designed for a search system that no longer exists. Citation equity is what AI systems use to decide which brands to cite.",
          "url": "https://ranking-atlas.com/resources/citation-equity-vs-link-building",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-03-01",
          "dateModified": "2026-04-01"
        }
      }
    ]
  }
};
---

<Layout
  title="Resources — Ranking Atlas"
  description="Primary-source research on backlink pricing, AI search visibility, and citation equity for B2B SaaS marketing teams."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="py-20 md:py-28">
  <div class="max-w-4xl mx-auto px-6">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-6">
      Research and Analysis for B2B SaaS Marketing Teams
    </h1>

    <div class="flex items-center gap-3 mb-6">
      <a href="/about" class="shrink-0">
        <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-12 h-12 rounded-full object-cover" width="48" height="48" />
      </a>
      <div>
        <p class="text-sm font-medium text-ink">Research and analysis by <a href="/about" class="text-brand hover:text-brand-dark transition-colors">Daniel Grainger</a>, founder of Ranking Atlas</p>
        <p class="text-sm text-[#64748B]">Updated April 2026</p>
      </div>
    </div>

    <p class="text-body text-lg md:text-xl leading-relaxed max-w-3xl mb-4">
      Primary-source research on the economics of editorial coverage, the mechanics of AI search citation, and the shift from link building to citation equity. The dataset behind the pricing index covers 140,000+ publisher listings across six years.
    </p>
    <p class="text-body text-lg leading-relaxed max-w-3xl">
      The essay frames the category shift. The guide explains the mechanism AI systems use to pick citations. The pricing index benchmarks what editorial coverage actually costs.
    </p>
  </div>
</section>

<section class="py-16 md:py-24 bg-bg-cream">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-8">

    <a href="/resources/ai-search-visibility" class="group bg-white rounded-2xl shadow-card p-8 hover:shadow-lg transition-shadow block">
      <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Guide</div>
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
        AI Search Visibility
      </h2>
      <p class="text-body leading-relaxed mb-4">
        How ChatGPT, Perplexity, Google AI Overviews, and Gemini choose which brands to mention. Citation equity is what puts you in the answer.
      </p>
      <p class="text-sm text-[#64748B] mb-4">Updated April 2026</p>
      <div class="text-sm text-brand font-medium group-hover:underline">Read the guide →</div>
    </a>

    <a href="/resources/the-cost-of-authority" class="group bg-white rounded-2xl shadow-card p-8 hover:shadow-lg transition-shadow block">
      <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Data Report</div>
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
        The Cost of Authority: 2026 Backlink Pricing Index
      </h2>
      <p class="text-body leading-relaxed mb-4">
        Primary-source pricing data across 140,000+ publisher listings and six years of agency snapshots. What backlinks cost, how pricing has moved 2020–2026, and why the market is solving the wrong problem.
      </p>
      <p class="text-sm text-[#64748B] mb-4">Updated April 2026</p>
      <div class="text-sm text-brand font-medium group-hover:underline">Read the report →</div>
    </a>

    <a href="/resources/citation-equity-vs-link-building" class="group bg-white rounded-2xl shadow-card p-8 hover:shadow-lg transition-shadow block md:col-span-2">
      <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Essay</div>
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
        Citation Equity vs Link Building: Why the Old Playbook Stops Working
      </h2>
      <p class="text-body leading-relaxed mb-4">
        Link-building was designed for a search system that no longer exists. Citation equity is what AI systems use to decide which brands to cite. Here's the difference, the evidence, and why one compounds while the other decays.
      </p>
      <p class="text-sm text-[#64748B] mb-4">Updated April 2026</p>
      <div class="text-sm text-brand font-medium group-hover:underline">Read the essay →</div>
    </a>

  </div>
</section>

</Layout>
