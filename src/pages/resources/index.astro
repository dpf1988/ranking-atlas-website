---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Research and Analysis for B2B SaaS Marketing Teams",
  "url": "https://ranking-atlas.com/resources/",
  "author": {
    "@type": "Person",
    "name": "Daniel Grainger",
    "url": "https://ranking-atlas.com/about",
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com"
    },
    "sameAs": [
      "https://www.linkedin.com/in/daniel-grainger/",
      "https://ranking-atlas.com/about"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Ranking Atlas",
    "url": "https://ranking-atlas.com"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Dataset",
          "headline": "Who AI Names When You Ask for ICT Experts",
          "description": "2,286 named individuals from 2,520 AI responses across ChatGPT, Claude, Gemini, and Perplexity. Gender, role, sub-category, and consensus data for every person named as an ICT expert.",
          "url": "https://ranking-atlas.com/resources/ai-names-ict-experts/",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-04-24",
          "dateModified": "2026-04-24"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Dataset",
          "headline": "SaaS Price Comparison 2020–2026",
          "description": "Entry-tier pricing for 65 SaaS tools tracked over six years across 12 categories, with Wayback Machine verification.",
          "url": "https://ranking-atlas.com/resources/saas-pricing-inflation",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-04-13",
          "dateModified": "2026-04-13"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Article",
          "headline": "How Paid Link Prices Rose While Their Value Collapsed",
          "description": "Primary-source pricing analysis of editorial coverage and link marketplace rates from 140,000+ publisher listings and six years of agency snapshots.",
          "url": "https://ranking-atlas.com/resources/the-cost-of-authority",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-03-01",
          "dateModified": "2026-04-01"
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Article",
          "headline": "Why Earned Links Beat Paid Links",
          "description": "The framework we apply across client campaigns. AI systems cite brands mentioned across heavy-hitting domains. Earned links produce those mentions. Paid links get deindexed and disappear. Here's the difference, the evidence, and the economics.",
          "url": "https://ranking-atlas.com/resources/earned-links-vs-paid-links",
          "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Ranking Atlas", "url": "https://ranking-atlas.com" }, "sameAs": ["https://www.linkedin.com/in/daniel-grainger/", "https://ranking-atlas.com/about"] },
          "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
          "datePublished": "2026-03-01",
          "dateModified": "2026-04-01"
        }
      }
    ]
  }
};
---

<Layout
  title="Resources — Ranking Atlas"
  description="Primary-source research on backlink pricing, AI search visibility, and citation equity for B2B SaaS marketing teams."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="py-20 md:py-28">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-12">
      <Eyebrow label="Resources" />
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-4">
        Industry Insights
      </h1>
      <p class="text-lg md:text-xl text-muted leading-relaxed">
        The state of citation equity, AI search visibility, and editorial authority in 2026.
      </p>
    </div>

    <!-- Resource card grid -->
    <div class="grid md:grid-cols-2 gap-8">

      <a href="/resources/ai-names-ict-experts/" class="group bg-white rounded-2xl shadow-card border border-[#0A0F1E]/8 p-8 hover:shadow-lg hover:border-[#5D4FE0]/20 transition-all duration-300 block flex flex-col">
        <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Original Data</div>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
          Who AI Names When You Ask for ICT Experts
        </h2>
        <p class="text-body leading-relaxed mb-4">
          2,286 individuals extracted from 2,520 AI responses. Women are named 20.5% of the time — against a 28% workforce share. Query phrasing shifts that figure by 16 percentage points.
        </p>
        <p class="text-sm text-muted mb-6">Published April 2026</p>
        <div class="mt-auto flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-8 h-8 rounded-full object-cover" width="32" height="32" />
            <span class="text-sm text-muted">Daniel Grainger</span>
          </div>
          <div class="text-sm text-brand font-medium group-hover:underline">View dataset →</div>
        </div>
      </a>

      <a href="/resources/saas-pricing-inflation" class="group bg-white rounded-2xl shadow-card border border-[#0A0F1E]/8 p-8 hover:shadow-lg hover:border-[#5D4FE0]/20 transition-all duration-300 block flex flex-col">
        <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Original Data</div>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
          SaaS Price Comparison 2020–2026
        </h2>
        <p class="text-body leading-relaxed mb-4">
          Entry-tier pricing for 65 tools tracked over six years. Tools replicable by AI show no pricing power. Tools that aren't raised prices well above inflation.
        </p>
        <p class="text-sm text-muted mb-6">Published April 2026</p>
        <div class="mt-auto flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-8 h-8 rounded-full object-cover" width="32" height="32" />
            <span class="text-sm text-muted">Daniel Grainger</span>
          </div>
          <div class="text-sm text-brand font-medium group-hover:underline">View dataset →</div>
        </div>
      </a>

      <a href="/resources/the-cost-of-authority" class="group bg-white rounded-2xl shadow-card border border-[#0A0F1E]/8 p-8 hover:shadow-lg hover:border-[#5D4FE0]/20 transition-all duration-300 block flex flex-col">
        <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Data Report</div>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
          How Paid Link Prices Rose While Their Value Collapsed
        </h2>
        <p class="text-body leading-relaxed mb-4">
          Paid links are more expensive than ever, and lower quality than ever. Six years of pricing data shows the gap.
        </p>
        <p class="text-sm text-muted mb-6">Updated April 2026</p>
        <div class="mt-auto flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-8 h-8 rounded-full object-cover" width="32" height="32" />
            <span class="text-sm text-muted">Daniel Grainger</span>
          </div>
          <div class="text-sm text-brand font-medium group-hover:underline">Read the report →</div>
        </div>
      </a>

      <a href="/resources/earned-links-vs-paid-links" class="group bg-white rounded-2xl shadow-card border border-[#0A0F1E]/8 p-8 hover:shadow-lg hover:border-[#5D4FE0]/20 transition-all duration-300 block flex flex-col">
        <div class="text-xs uppercase tracking-wider text-brand font-medium mb-3">Essay</div>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-ink mb-4 leading-snug group-hover:text-[#5D4FE0] transition-colors">
          Why Earned Links Beat Paid Links
        </h2>
        <p class="text-body leading-relaxed mb-4">
          Earned links get cited in AI answers. Paid links get deindexed. Here's the difference and the economics.
        </p>
        <p class="text-sm text-muted mb-6">Updated April 2026</p>
        <div class="mt-auto flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-8 h-8 rounded-full object-cover" width="32" height="32" />
            <span class="text-sm text-muted">Daniel Grainger</span>
          </div>
          <div class="text-sm text-brand font-medium group-hover:underline">Read the essay →</div>
        </div>
      </a>

    </div>
  </div>
</section>

</Layout>
