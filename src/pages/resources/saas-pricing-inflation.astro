            <tr class="hover:bg-[#FBFAF7] transition-colors"><td class="px-4 py-3 font-medium text-ink">Venngage</td><td class="px-4 py-3 text-[#64748B]">Visual Design</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$49.00</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$19.00</td><td class="px-4 py-3 text-right text-[#047857] font-semibold">-61.2%</td></tr>
            <tr class="hover:bg-[#FBFAF7] transition-colors"><td class="px-4 py-3 font-medium text-ink">Copper</td><td class="px-4 py-3 text-[#64748B]">CRM</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$24.00</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$12.00</td><td class="px-4 py-3 text-right text-[#047857] font-semibold">-50.0%</td></tr>
