            <tr class="hover:bg-[#FBFAF7] transition-colors"><td class="px-4 py-3 font-medium text-ink">Constant Contact</td><td class="px-4 py-3 text-[#64748B]">Marketing</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$20.00</td><td class="px-4 py-3 text-right text-[#64748B] font-mono">$12.00</td><td class="px-4 py-3 text-right text-[#047857] font-semibold">-40.0%</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── 7. Finding 4: Archived source snapshots ─────────────────────── -->
  <section id="snapshots" class="py-16 bg-[#FBFAF7] border-b border-[#0A0F1E]/8">
    <div class="max-w-3xl mx-auto px-6">
