---
import Layout from '../../layouts/Layout.astro';
import AuthorBio from '../../components/AuthorBio.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "SaaS Price Comparison 2020–2026 Dataset",
  "description": "Lowest monthly entry-tier pricing for 65 SaaS tools, captured from Wayback Machine snapshots (January 2020) and current vendor pricing pages (April 2026). Category medians, methodology, and archived source material.",
  "url": "https://ranking-atlas.com/resources/saas-pricing-inflation",
  "author": {
    "@type": "Person",
    "name": "Daniel Grainger",
    "url": "https://ranking-atlas.com/about",
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com"
    },
    "sameAs": [
      "https://www.linkedin.com/in/daniel-grainger/",
      "https://ranking-atlas.com/about"
    ]
  },
  "datePublished": "2026-04-13",
  "dateModified": "2026-04-13",
  "publisher": { "@type": "Organization", "name": "Ranking Atlas" },
  "distribution": {
    "@type": "DataDownload",
    "encodingFormat": "text/csv",
    "contentUrl": "https://ranking-atlas.com/downloads/saas-pricing-inflation-2020-2026.csv"
  }
};
---

<Layout
  title="SaaS Price Comparison 2020–2026 | Ranking Atlas"
  description="Lowest monthly entry-tier pricing for 65 SaaS tools, captured from Wayback Machine snapshots (January 2020) and current vendor pricing pages (April 2026). Category medians, methodology, and archived source material."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<div class="bg-white">

  <!-- ── 1. Hero section ──────────────────────────────────────────────── -->
  <section class="pt-20 md:pt-28 pb-16 border-b border-[#0A0F1E]/8">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-sm uppercase tracking-wider text-brand font-medium mb-3">Original Data</div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-6">
        SaaS Price Comparison 2020–2026
      </h1>
      <p class="text-body text-[21px] leading-[1.7] max-w-3xl mb-4">
        We pulled the lowest-priced monthly subscription from 65 SaaS vendor pricing pages in January 2020, then repeated the exercise in April 2026. 2020 prices were verified against the closest available <a href="https://web.archive.org" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark underline underline-offset-2">Wayback Machine</a> snapshot for each tool. 2026 prices were taken from live pricing pages captured in the same month. The result is a like-for-like record of entry-tier price movement across 12 software categories over six years.
      </p>
      <p class="text-body text-[21px] leading-[1.7] max-w-3xl mb-6">
        The pattern is consistent: tools whose core function can be approximated by a vibe-coded side project have no pricing power. The categories most exposed to AI replication — CRM, project management, productivity, dev tooling — show median price changes at or below zero. Categories that require human process, compliance, or integrations that AI cannot yet replicate — HR, accounting, support, analytics — raised prices well above inflation.
      </p>
      <div class="flex items-center gap-3 mb-4">
        <a href="/about" class="shrink-0">
          <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-12 h-12 rounded-full object-cover" width="48" height="48" />
        </a>
        <div>
          <p class="text-sm font-medium text-ink">By <a href="/about" class="text-brand hover:text-brand-dark transition-colors">Daniel Grainger</a>, founder of Ranking Atlas</p>
          <p class="text-sm text-[#64748B]">Published April 2026 &nbsp;·&nbsp; 65 tools across 12 categories</p>
        </div>
      </div>
      <a href="/downloads/saas-pricing-inflation-2020-2026.csv" class="inline-flex items-center gap-1.5 text-sm text-brand hover:text-brand-dark transition-colors font-medium">
        Download CSV
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </a>
    </div>
  </section>

  <!-- ── 2. Archived source snapshots ────────────────────────────────── -->
  <section class="py-16 bg-[#F8F7FA] border-b border-[#0A0F1E]/8">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mb-3">Archived Source Snapshots</h2>
      <p class="text-body text-[17px] leading-[1.7] mb-10 max-w-3xl">
        Two examples of Wayback Machine snapshots used to verify 2020 pricing. Full set of source snapshots available on request.
      </p>

      <!-- Kayako -->
      <div class="mb-12">
        <h3 class="text-lg font-bold tracking-tight text-ink mb-2">Kayako — Entry Tier 2020 vs 2026</h3>
        <p class="text-body text-[16px] leading-[1.7] mb-6 max-w-3xl">Kayako's lowest paid monthly subscription rose from $15 per agent per month in January 2020 to $79 per agent per month for Kayako One in April 2026, a 427% increase.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <figure>
            <img
              src="/assets/images/saas-pricing/kayako-2020.png"
              alt="Kayako pricing page, January 2020 — $15 per agent per month"
              class="w-full rounded-xl border border-[#0A0F1E]/8 shadow-card"
              onerror="this.style.opacity='0.3'"
            />
            <figcaption class="mt-2 text-sm text-[#64748B]">
              Kayako pricing, January 2020. Source: <a href="https://web.archive.org/web/20200101000000*/kayako.com/pricing" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark transition-colors">Wayback Machine archive</a>.
            </figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/saas-pricing/kayako-2026.png"
              alt="Kayako pricing page, April 2026 — $79 per agent per month"
              class="w-full rounded-xl border border-[#0A0F1E]/8 shadow-card"
              onerror="this.style.opacity='0.3'"
            />
            <figcaption class="mt-2 text-sm text-[#64748B]">
              Kayako pricing, April 2026. Source: <a href="https://www.kayako.com/pricing" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark transition-colors">kayako.com/pricing</a>.
            </figcaption>
          </figure>
        </div>
      </div>

      <!-- Asana -->
      <div>
        <h3 class="text-lg font-bold tracking-tight text-ink mb-2">Asana — Six Years Unchanged</h3>
        <p class="text-body text-[16px] leading-[1.7] mb-6 max-w-3xl">Asana's Premium tier (now Starter) has held at $10.99 per user per month since January 2020.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <figure>
            <img
              src="/assets/images/saas-pricing/asana-2020.png"
              alt="Asana pricing page, January 2020 — $10.99 per user per month"
              class="w-full rounded-xl border border-[#0A0F1E]/8 shadow-card"
              onerror="this.style.opacity='0.3'"
            />
            <figcaption class="mt-2 text-sm text-[#64748B]">
              Asana pricing, January 2020. Source: <a href="https://web.archive.org/web/20200101000000*/asana.com/pricing" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark transition-colors">Wayback Machine archive</a>.
            </figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/saas-pricing/asana-2026.png"
              alt="Asana pricing page, April 2026 — $10.99 per user per month"
              class="w-full rounded-xl border border-[#0A0F1E]/8 shadow-card"
