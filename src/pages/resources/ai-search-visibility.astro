<script>
  var aiOpenIndex: number | null = null;

  document.querySelectorAll('.ai-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var i = parseInt((btn as HTMLElement).getAttribute('data-ai-index') || '0');
      var item = (btn as HTMLElement).closest('.ai-faq-item');
      var answer = item ? item.querySelector('.ai-faq-answer') : null;
      var chevron = item ? item.querySelector('.ai-faq-chevron') : null;
      var question = item ? item.querySelector('.ai-faq-question') : null;

      if (aiOpenIndex === i) {
        if (answer) answer.classList.add('hidden');
        if (chevron) (chevron as HTMLElement).setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
        if (question) (question as HTMLElement).setAttribute('style', 'color: white');
        aiOpenIndex = null;
      } else {
        if (aiOpenIndex !== null) {
          var prevBtn = document.querySelector('[data-ai-index="' + aiOpenIndex + '"]');
          var prevItem = prevBtn ? (prevBtn as HTMLElement).closest('.ai-faq-item') : null;
          if (prevItem) {
            var pa = prevItem.querySelector('.ai-faq-answer');
            var pc = prevItem.querySelector('.ai-faq-chevron');
            var pq = prevItem.querySelector('.ai-faq-question');
            if (pa) pa.classList.add('hidden');
            if (pc) (pc as HTMLElement).setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
            if (pq) (pq as HTMLElement).setAttribute('style', 'color: white');
          }
        }
        if (answer) answer.classList.remove('hidden');
        if (chevron) (chevron as HTMLElement).setAttribute('style', 'color: #5D4FE0; transform: rotate(180deg)');
        if (question) (question as HTMLElement).setAttribute('style', 'color: #5D4FE0');
        aiOpenIndex = i;
      }
    });
  });
</script>
