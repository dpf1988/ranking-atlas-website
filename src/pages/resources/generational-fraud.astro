const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Who Actually Gets Scammed in America?",
  "description": "Federal fraud and survey data show sharp divides in who gets scammed, how often, and how much they lose.",
  "url": "https://ranking-atlas.com/resources/generational-fraud",
  "image": "https://ranking-atlas.com/assets/images/resources/generational-fraud/hero.jpg",
  "author": { "@type": "Person", "name": "Daniel Grainger", "url": "https://ranking-atlas.com/about" },
  "datePublished": "2026-03-15T00:00:00+00:00",
  "dateModified": "2026-05-14T00:00:00+00:00",
