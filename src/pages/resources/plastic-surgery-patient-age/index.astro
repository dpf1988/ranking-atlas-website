---
import Layout from '../../../layouts/Layout.astro';
import AuthorBio from '../../../components/AuthorBio.astro';
import RelatedResearch from '../../../components/RelatedResearch.astro';

const canonicalUrl = "https://ranking-atlas.com/resources/plastic-surgery-patient-age/";
const ogImage = "https://ranking-atlas.com/assets/images/resources/plastic-surgery-patient-age/hero.jpg";
const pageTitle = "How Old Are Plastic Surgery Patients in the US? Mean Age by Procedure, 2018–2024";
const pageDescription = "Mean age of US plastic surgery patients across 14 procedures from 2018 to 2024, drawn entirely from ASPS Statistics Reports. Full procedure-by-procedure data, interactive chart, methodology, and FAQ.";

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonicalUrl}#article`,
      "headline": pageTitle,
      "description": pageDescription,
      "url": canonicalUrl,
      "datePublished": "2026-04-29",
      "dateModified": "2026-04-29",
      "inLanguage": "en-US",
      "author": { "@id": "https://ranking-atlas.com/#organization" },
      "publisher": { "@id": "https://ranking-atlas.com/#organization" },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
      },
      "image": ogImage,
      "about": [
        { "@type": "Thing", "name": "Plastic surgery" },
        { "@type": "Thing", "name": "Cosmetic surgery demographics" },
        { "@type": "Thing", "name": "Patient age statistics" }
      ],
      "citation": [
        {
          "@type": "CreativeWork",
          "name": "Plastic Surgery Statistics Report 2024",
          "publisher": "American Society of Plastic Surgeons",
          "url": "https://www.plasticsurgery.org/news/plastic-surgery-statistics"
        },
        {
          "@type": "CreativeWork",
          "name": "Plastic Surgery Statistics Report 2023",
          "publisher": "American Society of Plastic Surgeons",
          "url": "https://www.plasticsurgery.org/news/plastic-surgery-statistics"
        },
        {
          "@type": "CreativeWork",
          "name": "Plastic Surgery Statistics Report 2022",
          "publisher": "American Society of Plastic Surgeons",
          "url": "https://www.plasticsurgery.org/news/plastic-surgery-statistics"
        }
      ]
    },
    {
      "@type": "Dataset",
      "@id": `${canonicalUrl}#dataset`,
      "name": "The Modern Plastic Surgery Patient: Age, 2018–2024",
      "description": "Mean patient age for 14 plastic surgery procedures across six measured years (2018, 2020, 2021 interpolated, 2022, 2023, 2024), computed as count-weighted bracket midpoints from American Society of Plastic Surgeons Statistics Reports.",
      "url": canonicalUrl,
      "creator": { "@id": "https://ranking-atlas.com/#organization" },
      "publisher": { "@id": "https://ranking-atlas.com/#organization" },
      "datePublished": "2026-04-29",
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "keywords": ["plastic surgery", "patient age", "cosmetic surgery demographics", "ASPS", "United States"],
      "isBasedOn": "https://www.plasticsurgery.org/news/plastic-surgery-statistics",
      "temporalCoverage": "2018/2024",
      "spatialCoverage": { "@type": "Place", "name": "United States" },
      "variableMeasured": "Mean patient age (years), per procedure, per year",
      "distribution": [
        {
          "@type": "DataDownload",
          "encodingFormat": "text/csv",
          "contentUrl": "https://ranking-atlas.com/resources/plastic-surgery-patient-age/data.csv"
        },
        {
          "@type": "DataDownload",
          "encodingFormat": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
          "contentUrl": "https://ranking-atlas.com/resources/plastic-surgery-patient-age/data.xlsx"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the average age of a plastic surgery patient in the United States?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is no single average age across all plastic surgery, because procedure mix and age distribution differ widely. In 2024, mean age ranged from 32.6 years for gynecomastia to 55.3 years for facelift across the 14 procedures tracked by the American Society of Plastic Surgeons. The procedure-age hierarchy has been stable since 2018: face procedures cluster in the 50s, injectables in the mid-40s, breast and body work in the mid-30s to early 40s, and rhinoplasty and otoplasty under 35."
          }
        },
        {
          "@type": "Question",
          "name": "Are plastic surgery patients getting younger?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, not in aggregate. Of the 14 procedures tracked by the American Society of Plastic Surgeons, eight are older in 2024 than in 2018, four are younger, and two are flat. The largest sustained increase is gynecomastia at +4.1 years; the largest sustained decrease is eyelid surgery at \u22122.5 years. The popular 'younger patients' narrative is partly an artifact of mixing ASPS and ASAPS data, which used different age brackets and different sampling frames."
          }
        },
        {
          "@type": "Question",
          "name": "What is the average age of breast augmentation patients in the US?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The mean age of US breast augmentation patients was 35.5 years in 2024, up from 32.5 in 2018. The 2020 value of 30.1 was a pandemic-year outlier; the procedure has since recovered and stabilized at roughly 35.5 across 2022, 2023, and 2024."
          }
        },
        {
          "@type": "Question",
          "name": "What is the average age of facelift patients in the US?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The mean age of US facelift patients was 55.3 years in 2024, down slightly from 56.0 in 2018. Facelift mean age has been within a one-year range across the entire 2018 to 2024 window. It is the oldest mean-age procedure in the American Society of Plastic Surgeons dataset."
          }
        },
        {
          "@type": "Question",
          "name": "What is the average age of Botox patients in the US?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The mean age of US botulinum toxin patients was 44.8 years in 2024, down from 46.0 in 2018. Botox mean age has been flat at 44.8 across 2022, 2023, and 2024 according to American Society of Plastic Surgeons data."
          }
        },
        {
          "@type": "Question",
          "name": "Has the average age of plastic surgery patients changed since the pandemic?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There was a clear COVID-19 effect that has now resolved. In 2020, body and breast procedures saw a sharp drop in mean age. By 2022 every one of these procedures had returned to its 2018 baseline or exceeded it. By 2024 mean age had been flat for three consecutive years across most of the 14 procedures tracked by the American Society of Plastic Surgeons."
          }
        },
        {
          "@type": "Question",
          "name": "What is the youngest plastic surgery procedure by patient age?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Otoplasty (ear pinning) is the youngest procedure, with a 2024 mean age of 26.4 years. This reflects that otoplasty is performed on children and teenagers as well as adults. Among predominantly-adult procedures, gynecomastia (male breast reduction) is the youngest, with a 2024 mean age of 32.6 years."
          }
        },
        {
          "@type": "Question",
          "name": "Why do these numbers differ from other plastic surgery age statistics?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most published statistics combine American Society of Plastic Surgeons (ASPS) and Aesthetic Society (ASAPS) data without flagging the methodology change. The two organizations use different age brackets and different sampling frames, and ASAPS stopped publishing annual reports after 2019. Combining the two sources produces apparent age changes of 1 to 3 years that are measurement artifacts. This dataset uses ASPS only, with bracket midpoints stated openly in the methodology."
          }
        }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://ranking-atlas.com/#organization",
      "name": "Ranking Atlas",
      "url": "https://ranking-atlas.com",
      "logo": "https://ranking-atlas.com/logo.png",
      "description": "Ranking Atlas is a digital PR agency producing single-source data research for editorial pickup.",
      "sameAs": ["https://www.linkedin.com/company/ranking-atlas"]
    }
  ]
};

const citationText = `Ranking Atlas (2026). How Old Are Plastic Surgery Patients in the US? Mean Age by Procedure, 2018\u20132024. Compiled from the American Society of Plastic Surgeons Plastic Surgery Statistics Report. https://ranking-atlas.com/resources/plastic-surgery-patient-age/`;
---

<Layout
  title={`${pageTitle} | Ranking Atlas`}
  description={pageDescription}
>
  <fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Ranking Atlas" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </fragment>

<div class="bg-white">

  <!-- ── ARTICLE HEADER (Article Header Pattern) ─────────────────────── -->
  <article class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">

      <div class="text-sm uppercase tracking-wider text-brand font-medium mb-3">Data Report</div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-6">
        How Old Are Plastic Surgery Patients in the US?
      </h1>

      <div class="flex items-center gap-3 mb-8">
        <a href="/about" class="shrink-0">
          <img src="/assets/images/author/daniel-headshot.jpg" alt="Daniel Grainger" class="w-12 h-12 rounded-full object-cover" width="48" height="48" />
        </a>
        <div>
          <p class="text-sm font-medium text-ink">By <a href="/about" class="text-brand hover:text-brand-dark transition-colors">Daniel Grainger</a>, founder of Ranking Atlas</p>
          <p class="text-sm text-muted">Published April 2026 &nbsp;·&nbsp; 14 procedures &nbsp;·&nbsp; 2018–2024 &nbsp;·&nbsp; ASPS data only</p>
        </div>
      </div>

      <p class="text-body text-[21px] leading-[1.7] max-w-3xl mb-8">
        This <a href="/" class="text-brand hover:text-brand-dark underline underline-offset-2">Ranking Atlas</a> data report compiles mean patient age across 14 procedures from 2018 to 2024, drawn entirely from the American Society of Plastic Surgeons Statistics Reports. Each figure traces to a single primary source. No bracket-shifting, no silent vendor blending.
      </p>

      <!-- Quick-reference table (replaces hero image for this data report) -->
      <div class="bg-white border border-[#0A0F1E]/8 rounded-2xl shadow-card mb-10 overflow-hidden">
        <div class="px-6 pt-5 pb-3 border-b border-[#0A0F1E]/8">
          <p class="text-sm font-semibold text-ink">Mean age by procedure, 2024. American Society of Plastic Surgeons (ASPS).</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="border-b border-[#0A0F1E]/8 bg-[#F8F7FA]">
                <th class="px-6 py-3 font-semibold text-ink">Procedure</th>
                <th class="px-6 py-3 font-semibold text-ink text-right">Mean Age (2024)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#0A0F1E]/6">
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Facelift</td><td class="px-6 py-2.5 text-right text-body">55.3</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Neck Lift</td><td class="px-6 py-2.5 text-right text-body">52.3</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Eyelid Surgery</td><td class="px-6 py-2.5 text-right text-body">51.1</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Forehead Lift</td><td class="px-6 py-2.5 text-right text-body">50.7</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">HA Fillers</td><td class="px-6 py-2.5 text-right text-body">46.1</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Botulinum Toxin (Botox)</td><td class="px-6 py-2.5 text-right text-body">44.8</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Breast Lift</td><td class="px-6 py-2.5 text-right text-body">40.1</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Breast Reduction</td><td class="px-6 py-2.5 text-right text-body">38.4</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Abdominoplasty</td><td class="px-6 py-2.5 text-right text-body">37.8</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Liposuction</td><td class="px-6 py-2.5 text-right text-body">36.8</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Breast Augmentation</td><td class="px-6 py-2.5 text-right text-body">35.5</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Rhinoplasty</td><td class="px-6 py-2.5 text-right text-body">33.3</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Gynecomastia</td><td class="px-6 py-2.5 text-right text-body">32.6</td></tr>
              <tr class="hover:bg-[#F8F7FA] transition-colors"><td class="px-6 py-2.5 text-body">Otoplasty</td><td class="px-6 py-2.5 text-right text-body">26.4</td></tr>
            </tbody>
          </table>
        </div>
        <p class="px-6 py-3 text-xs text-muted border-t border-[#0A0F1E]/8">Source: ASPS Plastic Surgery Statistics Report 2024. <a href="#dataset" class="text-brand hover:text-brand-dark underline underline-offset-2">Full 2018–2024 dataset below.</a></p>
      </div>

      <!-- ToC / summary box -->
      <div class="bg-white border border-[#0A0F1E]/8 rounded-xl p-6 mb-10 shadow-card">
        <p class="text-sm font-semibold text-ink mb-3">Key findings</p>
        <ul class="space-y-2 text-sm text-body leading-[1.7] list-disc pl-5">
          <li>Mean patient age in 2024 ranges from <strong>26.4 years</strong> (otoplasty) to <strong>55.3 years</strong> (facelift). There is no single "average patient."</li>
          <li><strong>Nine of 14 procedures</strong> have been flat since 2022. The post-pandemic demographic correction has ended.</li>
          <li>Gynecomastia rose <strong>4.1 years</strong> since 2018, the largest sustained increase in the dataset.</li>
          <li>Eyelid surgery fell <strong>2.5 years</strong>, the largest sustained decrease.</li>
          <li>The procedure-age hierarchy (face in the 50s, injectables in the mid-40s, breast and body in the mid-30s to early 40s, nose and ears under 35) has not changed in any year since 2018.</li>
        </ul>
      </div>

      <!-- Download links -->
      <div class="flex flex-wrap gap-4 mb-2">
        <a href="/resources/plastic-surgery-patient-age/data.csv" class="inline-flex items-center gap-1.5 text-sm text-brand hover:text-brand-dark transition-colors font-medium">
          Download data (CSV)
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
        <a href="/resources/plastic-surgery-patient-age/data.xlsx" class="inline-flex items-center gap-1.5 text-sm text-brand hover:text-brand-dark transition-colors font-medium">
          Download full workbook (XLSX)
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
      </div>

    </div>
  </article>

  <!-- ── 1. DATA TABLE ───────────────────────────────────────────────────── -->
  <section class="py-16 border-b border-[#0A0F1E]/8" id="dataset">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink leading-tight mb-3">Mean Age By Procedure, 2018 To 2024</h2>
      <p class="text-body text-[17px] leading-[1.7] mb-6 max-w-3xl">
        Each value is the count-weighted mean of bracket midpoints from the ASPS Statistics Report for that year. The 2021 value is interpolated: ASPS published a combined 2020–2021 report and did not separate the years. Full methodology detail is in the <a href="/resources/plastic-surgery-patient-age/methodology" class="text-brand hover:text-brand-dark underline underline-offset-2">methodology document</a>.
      </p>
