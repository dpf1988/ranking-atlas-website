        <line x1="60" y1="103" x2="460" y2="103" stroke="#F1F5F9" stroke-width="1"/>
        <line x1="60" y1="149" x2="460" y2="149" stroke="#F1F5F9" stroke-width="1"/>
        <line x1="60" y1="195" x2="460" y2="195" stroke="#F1F5F9" stroke-width="1"/>

        <!-- Y-axis labels -->
