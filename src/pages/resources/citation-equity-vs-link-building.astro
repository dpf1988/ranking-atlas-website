        <text x="513" y="69" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" font-weight="600" fill="#5D4FE0">TechCrunch</text>

        <rect x="580" y="52" width="90" height="26" rx="5" fill="white" stroke="#5D4FE0" stroke-width="1.5"/>
        <text x="625" y="63" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="9" font-weight="600" fill="#5D4FE0">Financial</text>
        <text x="625" y="74" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="9" font-weight="600" fill="#5D4FE0">Times</text>

