        <text x="63" y="69" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#64748B">Linking domain</text>

        <rect x="120" y="52" width="90" height="26" rx="5" fill="#F1F5F9" stroke="#CBD5E1" stroke-width="1"/>
        <text x="165" y="69" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#64748B">Linking domain</text>

        <rect x="222" y="52" width="90" height="26" rx="5" fill="#F1F5F9" stroke="#CBD5E1" stroke-width="1"/>
        <text x="267" y="69" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#64748B">Linking domain</text>

        <!-- Arrows: domains to Your page (converging) -->
        <line x1="63" y1="78" x2="157" y2="158" stroke="#94A3B8" stroke-width="1.5" marker-end="url(#arr-gray)"/>
        <line x1="165" y1="78" x2="165" y2="158" stroke="#94A3B8" stroke-width="1.5" marker-end="url(#arr-gray)"/>
        <line x1="267" y1="78" x2="173" y2="158" stroke="#94A3B8" stroke-width="1.5" marker-end="url(#arr-gray)"/>

        <!-- "link" labels -->
        <text x="103" y="115" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="9" fill="#94A3B8">link</text>
