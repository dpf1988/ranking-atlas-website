        <text x="52" y="107" text-anchor="end" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#94A3B8">$150</text>
        <text x="52" y="153" text-anchor="end" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#94A3B8">$100</text>
        <text x="52" y="199" text-anchor="end" font-family="ui-sans-serif,system-ui,-apple-system" font-size="10" fill="#94A3B8">$50</text>

        <!-- Baseline -->
        <line x1="60" y1="240" x2="460" y2="240" stroke="#E2E8F0" stroke-width="2"/>

