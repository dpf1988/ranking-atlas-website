        <!-- ── RIGHT COLUMN ── -->
        <text x="515" y="20" text-anchor="middle" font-family="ui-sans-serif,system-ui,-apple-system" font-size="13" font-weight="700" fill="#0A0F1E">The 2026 Mechanism</text>
