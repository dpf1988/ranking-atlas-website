<script>
  // ── Copy cite button ──
  var copyBtn = document.getElementById('copyBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      var citeText = document.getElementById('citeText');
      if (citeText) {
        navigator.clipboard.writeText(citeText.textContent || '');
        copyBtn!.textContent = 'Copied!';
        setTimeout(function() { copyBtn!.textContent = 'Copy'; }, 2000);
      }
    });
  }

  // ── Heatmap ──
  var heatmapData = {
    drTiers: ['DR 20-30','DR 30-40','DR 40-50','DR 50-60','DR 60-70','DR 70-80','DR 80+'],
    trafficTiers: ['0–100','100–1k','1k–10k','10k–50k','50k+'],
    prices: [
      [50, 80, 130, 200, 300],
      [80, 140, 220, 340, 500],
      [120, 200, 320, 500, 750],
      [150, 280, 450, 700, 1200],
      [200, 380, 600, 950, 1800],
      [300, 550, 850, 1400, 2500],
      [500, 800, 1300, 2500, null]
    ]
  };

  function priceColor(val: number | null): string {
    if (val === null) return '#F1F5F9';
    if (val <= 100) return '#DCFCE7';
    if (val <= 200) return '#86EFAC';
    if (val <= 400) return '#4ADE80';
    if (val <= 700) return '#FCD34D';
    if (val <= 1200) return '#F97316';
    return '#EF4444';
  }

  function textColor(val: number | null): string {
    if (val === null) return '#94A3B8';
    if (val <= 400) return '#14532D';
    return '#FFFFFF';
  }

  function buildHeatmap() {
    var el = document.getElementById('heatmapEl');
    if (!el) return;
    var d = heatmapData;
    var h = '<table style="width:100%;border-collapse:collapse;font-size:13px">';
    h += '<thead><tr><th style="padding:10px 12px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;border-bottom:2px solid rgba(10,15,30,0.08);min-width:90px">DR \\ Traffic</th>';
    for (var t = 0; t < d.trafficTiers.length; t++) {
      h += '<th style="padding:10px 12px;text-align:center;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;border-bottom:2px solid rgba(10,15,30,0.08);min-width:80px">' + d.trafficTiers[t] + '</th>';
    }
    h += '</tr></thead><tbody>';
    for (var i = 0; i < d.drTiers.length; i++) {
      h += '<tr><td style="padding:12px;font-weight:600;color:#0A0F1E;border-bottom:1px solid rgba(10,15,30,0.06)">' + d.drTiers[i] + '</td>';
      for (var j = 0; j < d.trafficTiers.length; j++) {
        var val = d.prices[i][j];
        var bg = priceColor(val);
        var tc = textColor(val);
        var display = val === null ? '—' : '$' + val.toLocaleString();
        h += '<td style="padding:12px;text-align:center;font-family:ui-monospace,monospace;font-weight:500;font-size:13px;background:' + bg + ';color:' + tc + ';border-bottom:1px solid rgba(10,15,30,0.06);border-left:2px solid white">' + display + '</td>';
      }
      h += '</tr>';
    }
    h += '</tbody></table>';
    el.innerHTML = h;
  }
  buildHeatmap();
</script>
