<script>
  // ── Accordion ──
  var piOpenIndex: number | null = null;

  document.querySelectorAll('.pi-acc-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var i = parseInt((btn as HTMLElement).getAttribute('data-pi-index') || '0');
      var item = (btn as HTMLElement).closest('.pi-acc-item');
      var answer = item ? item.querySelector('.pi-acc-answer') : null;
      var chevron = item ? item.querySelector('.pi-acc-chevron') : null;
      var question = item ? item.querySelector('.pi-acc-question') : null;

      if (piOpenIndex === i) {
        if (answer) answer.classList.add('hidden');
        if (chevron) (chevron as HTMLElement).setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
        if (question) (question as HTMLElement).setAttribute('style', 'color: #0A0F1E');
        piOpenIndex = null;
      } else {
        if (piOpenIndex !== null) {
          var prevBtn = document.querySelector('[data-pi-index="' + piOpenIndex + '"]');
          var prevItem = prevBtn ? (prevBtn as HTMLElement).closest('.pi-acc-item') : null;
          if (prevItem) {
            var pa = prevItem.querySelector('.pi-acc-answer');
            var pc = prevItem.querySelector('.pi-acc-chevron');
            var pq = prevItem.querySelector('.pi-acc-question');
            if (pa) pa.classList.add('hidden');
            if (pc) (pc as HTMLElement).setAttribute('style', 'color: #64748B; transform: rotate(0deg)');
            if (pq) (pq as HTMLElement).setAttribute('style', 'color: #0A0F1E');
          }
        }
        if (answer) answer.classList.remove('hidden');
        if (chevron) (chevron as HTMLElement).setAttribute('style', 'color: #5D4FE0; transform: rotate(180deg)');
        if (question) (question as HTMLElement).setAttribute('style', 'color: #5D4FE0');
        piOpenIndex = i;
      }
    });
  });

  // ── Copy cite button ──
  var copyBtn = document.getElementById('copyBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      var citeText = document.getElementById('citeText');
      if (citeText) {
        navigator.clipboard.writeText(citeText.textContent || '');
        copyBtn!.textContent = 'Copied!';
        setTimeout(function() { copyBtn!.textContent = 'Copy'; }, 2000);
      }
    });
  }

  // ── Calculator ──
  var pricingData: Record<string, {gp: number, ne: number}> = {
    '20': { gp: 175, ne: 150 },
    '30': { gp: 282, ne: 225 },
    '40': { gp: 365, ne: 300 },
    '50': { gp: 500, ne: 400 },
    '60': { gp: 650, ne: 500 },
    '70': { gp: 930, ne: 700 },
    '80': { gp: 1500, ne: 1000 }
  };

  function updateCalc() {
    var numLinksEl = document.getElementById('numLinks') as HTMLInputElement;
    var drRangeEl = document.getElementById('drRange') as HTMLSelectElement;
    if (!numLinksEl || !drRangeEl) return;

    var n = Math.max(1, Math.min(100, parseInt(numLinksEl.value) || 10));
    var dr = drRangeEl.value;
    var drNum = parseInt(dr);
    var d = pricingData[dr];
    var gpTotal = d.gp * n;
    var neTotal = d.ne * n;
    var campaigns = Math.ceil(n / 12);
    var dprTotal = campaigns * 3500;
    var dprPer = Math.round(dprTotal / n);
    var minLinks = campaigns * 8;
    var marketplaceCheaper = (drNum <= 40 && d.ne * n < dprTotal);

    var html = '<p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;margin:0 0 10px">Buying links (marketplace)</p>';
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">';

    if (marketplaceCheaper) {
      html += '<div class="calc-result best"><div class="method" style="color:#15803D">Guest post</div><div class="total">$' + gpTotal.toLocaleString() + '</div><div class="per-link">$' + d.gp.toLocaleString() + ' per link</div></div>';
      html += '<div class="calc-result best"><div class="method" style="color:#15803D">Niche edit</div><div class="total">$' + neTotal.toLocaleString() + '</div><div class="per-link">$' + d.ne.toLocaleString() + ' per link</div></div>';
    } else {
      html += '<div class="calc-result"><div class="method">Guest post</div><div class="total">$' + gpTotal.toLocaleString() + '</div><div class="per-link">$' + d.gp.toLocaleString() + ' per link</div></div>';
      html += '<div class="calc-result"><div class="method">Niche edit</div><div class="total">$' + neTotal.toLocaleString() + '</div><div class="per-link">$' + d.ne.toLocaleString() + ' per link</div></div>';
    }
    html += '</div>';

    html += '<p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#15803D;margin:0 0 10px">Earning links (Ranking Atlas digital PR)</p>';

    if (marketplaceCheaper) {
      html += '<div class="calc-result neutral"><div class="method">' + campaigns + ' digital PR campaign' + (campaigns > 1 ? 's' : '') + ' &middot; $3,500 each</div><div class="total">$' + dprTotal.toLocaleString() + '</div><div class="per-link">Minimum ' + minLinks + ' earned placements guaranteed &middot; most campaigns deliver 8–12+ links &middot; fixed price regardless of how many links are secured</div></div>';
    } else {
      html += '<div class="calc-result best"><div class="method" style="color:#15803D">' + campaigns + ' digital PR campaign' + (campaigns > 1 ? 's' : '') + ' &middot; $3,500 each</div><div class="total">$' + dprTotal.toLocaleString() + '</div><div class="per-link">Minimum ' + minLinks + ' earned placements guaranteed &middot; most campaigns deliver 8–12+ links &middot; fixed price regardless of how many links are secured</div></div>';
    }

    var calcResultsEl = document.getElementById('calcResults');
    if (calcResultsEl) calcResultsEl.innerHTML = html;

    var note = document.getElementById('calcNote');
    if (note) {
      if (marketplaceCheaper) {
        note.textContent = 'At this DR range, marketplace links are more cost-effective for building foundational link diversity. Digital PR delivers links on publications with higher authority, real traffic, and editorial standards — consider it when you need links that also build brand recognition.';
      } else {
        note.textContent = 'At this DR range, earned links through digital PR are more cost-effective per link — and come with zero compliance risk, guaranteed real traffic, and brand-building benefits that marketplace links cannot deliver.';
      }
    }
  }

  var numLinksInput = document.getElementById('numLinks');
  var drRangeSelect = document.getElementById('drRange');
  if (numLinksInput) numLinksInput.addEventListener('input', updateCalc);
  if (drRangeSelect) drRangeSelect.addEventListener('change', updateCalc);
  updateCalc();

  // ── Heatmap ──
  var heatmapData = {
    drTiers: ['DR 20-30','DR 30-40','DR 40-50','DR 50-60','DR 60-70','DR 70-80','DR 80+'],
    trafficTiers: ['0–100','100–1k','1k–10k','10k–50k','50k+'],
    prices: [
      [50, 80, 130, 200, 300],
      [80, 140, 220, 340, 500],
      [120, 200, 320, 500, 750],
      [150, 280, 450, 700, 1200],
      [200, 380, 600, 950, 1800],
      [300, 550, 850, 1400, 2500],
      [500, 800, 1300, 2500, null]
    ]
  };

  function priceColor(val: number | null): string {
    if (val === null) return '#F1F5F9';
    if (val <= 100) return '#DCFCE7';
    if (val <= 200) return '#86EFAC';
    if (val <= 400) return '#4ADE80';
    if (val <= 700) return '#FCD34D';
    if (val <= 1200) return '#F97316';
    return '#EF4444';
  }

  function textColor(val: number | null): string {
    if (val === null) return '#94A3B8';
    if (val <= 400) return '#14532D';
    return '#FFFFFF';
  }

  function buildHeatmap() {
    var el = document.getElementById('heatmapEl');
    if (!el) return;
    var d = heatmapData;
    var h = '<table style="width:100%;border-collapse:collapse;font-size:13px">';
    h += '<thead><tr><th style="padding:10px 12px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;border-bottom:2px solid rgba(10,15,30,0.08);min-width:90px">DR \\ Traffic</th>';
    for (var t = 0; t < d.trafficTiers.length; t++) {
      h += '<th style="padding:10px 12px;text-align:center;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#94A3B8;border-bottom:2px solid rgba(10,15,30,0.08);min-width:80px">' + d.trafficTiers[t] + '</th>';
    }
    h += '</tr></thead><tbody>';
    for (var i = 0; i < d.drTiers.length; i++) {
      h += '<tr><td style="padding:12px;font-weight:600;color:#0A0F1E;border-bottom:1px solid rgba(10,15,30,0.06)">' + d.drTiers[i] + '</td>';
      for (var j = 0; j < d.trafficTiers.length; j++) {
        var val = d.prices[i][j];
        var bg = priceColor(val);
        var tc = textColor(val);
        var display = val === null ? '—' : '$' + val.toLocaleString();
        h += '<td style="padding:12px;text-align:center;font-family:ui-monospace,monospace;font-weight:500;font-size:13px;background:' + bg + ';color:' + tc + ';border-bottom:1px solid rgba(10,15,30,0.06);border-left:2px solid white">' + display + '</td>';
      }
      h += '</tr>';
    }
    h += '</tbody></table>';
    el.innerHTML = h;
  }
  buildHeatmap();
</script>
