---
import Layout from '../layouts/Layout.astro';
import PrimaryCTA from '../components/PrimaryCTA.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Daniel Grainger",
  "url": "https://ranking-atlas.com/about",
  "jobTitle": "Founder",
  "worksFor": {
    "@type": "Organization",
    "name": "Ranking Atlas",
    "url": "https://ranking-atlas.com"
  },
  "description": "Founder of Ranking Atlas. Applies research methodology to citation equity for B2B SaaS brands.",
  "sameAs": [
    "https://www.linkedin.com/in/daniel-grainger/",
    "https://onlinelibrary.wiley.com/doi/abs/10.1111/eth.12280"
  ]
};
---

<Layout
  title="About — Ranking Atlas"
  description="Ranking Atlas is a digital PR agency for B2B SaaS brands. We run fixed-price campaigns that earn editorial coverage on authoritative publishers, building the citation equity that puts brands in AI answers."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">

      <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4 text-[#64748B]">Our Story</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ink leading-[1.1] mb-8">
        About Ranking Atlas
      </h1>

      <p class="text-body text-lg md:text-xl leading-relaxed mb-8">
        Ranking Atlas is a digital PR agency for B2B SaaS brands. We run fixed-price campaigns that earn editorial coverage on authoritative publishers, building the citation equity that puts brands in AI answers.
      </p>
      <p class="text-body text-lg md:text-xl leading-relaxed">
        What makes Ranking Atlas different is how we approach the work.
      </p>

    </div>
  </section>

  <!-- Section 2: Founded on Research Principles -->
  <section class="py-10 md:py-14 bg-bg-cream">
    <div class="max-w-3xl mx-auto px-6">

      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-ink leading-tight mb-8">
        Founded on Research Principles
      </h2>

      <!-- Two-column founder intro block -->
      <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-8 md:gap-12 items-start mb-8">

        <!-- Left column: headshot + byline -->
        <div>
          <img
            src="/assets/images/author/daniel-headshot.jpg"
            alt="Daniel Grainger, Founder of Ranking Atlas"
            class="w-24 h-24 md:w-32 md:h-32 rounded-full object-cover shadow-card"
            width="128"
            height="128"
          />
          <p class="text-lg font-semibold text-ink mt-4">Daniel Grainger</p>
          <p class="text-sm text-[#64748B] mt-1">Founder, Ranking Atlas</p>
          <a
            href="https://www.linkedin.com/in/daniel-grainger/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-brand hover:text-brand-dark transition-colors mt-3"
          >
            <LinkedInIcon />
            LinkedIn
          </a>
        </div>

        <!-- Right column: first body paragraph -->
        <div class="text-body text-lg leading-relaxed">
          <p>
            Ranking Atlas was founded by Daniel Grainger. Before starting the agency, he trained as a scientist and <a href="https://onlinelibrary.wiley.com/doi/abs/10.1111/eth.12280" target="_blank" rel="noopener" class="text-brand hover:text-brand-dark underline underline-offset-2">published peer-reviewed research in <em>Ethology</em></a>, a Wiley journal.
          </p>
        </div>

      </div>

      <!-- Remaining body paragraphs — full width -->
      <div class="space-y-4 text-body text-lg leading-relaxed">
        <p>
          That training shaped how Ranking Atlas operates. Most PR agencies run on intuition: pitch a lot, see what lands, report on volume. We treat editorial coverage as an observable system with measurable signals. Campaigns are structured interventions. Outcomes are evidenced against data.
        </p>
        <p class="font-semibold text-ink py-2">
          The research discipline is the agency's foundation.
        </p>
      </div>

    </div>
  </section>

  <!-- Section 3: How We Work -->
  <section class="py-10 md:py-14">
    <div class="max-w-3xl mx-auto px-6">

      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-ink leading-tight mb-8">
        How We Work
      </h2>

      <div class="space-y-4 text-body text-lg leading-relaxed">
        <p>
          We run every campaign as a structured intervention. We baseline a brand's citation pattern before the campaign starts, identify the authoritative publishers AI systems cite in the client's vertical, target editorial coverage on those publishers, and measure the citation pattern after.
        </p>
        <p class="font-semibold text-ink py-2">
          Each step is documented. Each output is evidenced.
        </p>
        <p>
          Our published research follows the same discipline. The Cost of Authority report is built on a proprietary dataset of 140,000+ publisher listings collected over six years. The research we publish is the research we apply to client work.
        </p>
      </div>

    </div>
  </section>

  <!-- Section 4: What a Campaign Looks Like -->
  <section class="py-10 md:py-14 bg-bg-cream">
    <div class="max-w-3xl mx-auto px-6">

      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-ink leading-tight mb-8">
        What a Campaign Looks Like
      </h2>

      <div class="space-y-4 text-body text-lg leading-relaxed">
        <p>
          Fixed-price campaigns, not retainers. Every engagement has defined scope and a guaranteed minimum number of editorial placements. If we do not hit the guarantee, we keep working until we do.
        </p>
        <p>
          Every campaign includes before-and-after AI citation measurement across ChatGPT, Perplexity, Gemini, and Google AI Overviews. Clients see exactly how their brand's presence in AI answers shifted.
        </p>
        <p>
          No retainers. No monthly billing. One campaign, one price, one measurable outcome.
        </p>
        <p>
          If that's what you're looking for, start a campaign.
        </p>
      </div>

    </div>
  </section>

  <!-- CTA band -->
  <section class="relative overflow-hidden py-16 md:py-20 text-center" style="background: #5D4FE0;">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22/></filter><rect width=%22100%22 height=%22100%22 filter=%22url(%23n)%22/></svg>');"></div>
    <div class="relative max-w-4xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.1] mb-6">
        Ready to Start a Campaign?
      </h2>
      <p class="text-lg text-white/80 mb-10">$3.5K per campaign. Guaranteed editorial placements on authoritative publishers. No retainers.</p>
      <PrimaryCTA href="/contact" />
    </div>
  </section>

</Layout>
